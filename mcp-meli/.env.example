# Modelo do .env do cliente ML — copie para .env e preencha com os valores reais.
# Valores vêm do app criado no DevCenter (developers.mercadolivre.com.br).
# NÃO coloque valores reais aqui — este arquivo VAI para o git.

MELI_CLIENT_ID=
MELI_CLIENT_SECRET=
# redirect_uri DEVE ser HTTPS e idêntica à registrada no app. Pode ser uma URL
# do próprio domínio (a página não precisa existir — só capturamos o code da URL).
MELI_REDIRECT_URI=https://dropchinaoficial.com.br/oauth/meli

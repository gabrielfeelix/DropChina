# Modelo do .env do MCP Bling — copie para .env e preencha com os valores reais.
# Os valores reais vêm da aba "Informações do app" no painel do Bling.
# NÃO coloque valores reais aqui — este arquivo VAI para o git.

BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
BLING_REDIRECT_URI=http://localhost:3000/callback

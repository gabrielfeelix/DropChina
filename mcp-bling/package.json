{
  "name": "dropchina-bling-mcp",
  "version": "0.1.0",
  "description": "MCP server local para a API v3 do Bling (fonte da verdade do catálogo/estoque/fiscal do DropChina).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "authorize": "tsx src/scripts/authorize.ts",
    "seed:categorias": "tsx src/scripts/seed-categorias.ts",
    "mcp": "tsx src/mcp/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "bling-erp-api": "^5.8.1",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}

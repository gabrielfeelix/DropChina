    width: 100vw;
    height: 100vh;
    max-width: 100vw;
    max-height: 100vh;
    display: none;
    place-items: center;
  }
  .dc-pdp-lightbox[open] { display: grid; }
  .dc-pdp-lightbox::backdrop { background: transparent; }
  .dc-pdp-lightbox__img {
    max-width: 92vw;
    max-height: 88vh;
    width: auto;
    height: auto;
    object-fit: contain;
    cursor: zoom-in;
    transition: transform 0.25s ease;
    border-radius: 12px;
    background: #ffffff;
  }
  .dc-pdp-lightbox__img.is-zoomed {
    transform: scale(1.8);
    cursor: zoom-out;
  }
  .dc-pdp-lightbox__close {
    position: fixed;
    top: 20px;
    right: 20px;
    width: 46px;
    height: 46px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.95);
    color: #0d1115;
    border: 0;
    display: grid;
    place-items: center;
    cursor: pointer;
    z-index: 2;
  }
  .dc-pdp-lightbox__nav {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.95);
    color: #0d1115;
    border: 0;
    display: grid;
    place-items: center;
    cursor: pointer;
    z-index: 2;
  }
  .dc-pdp-lightbox__nav--prev { left: 18px; }
  .dc-pdp-lightbox__nav--next { right: 18px; }

  /* Trust */
  .dc-pdp-trust {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    padding: 18px 0;
    border-top: 1px solid #ececef;
    border-bottom: 1px solid #ececef;
  }
  .dc-pdp-trust__item {
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .dc-pdp-trust__item svg {
    color: #0d1115;
    flex: none;
  }
  .dc-pdp-trust__item b {
    display: block;
    font-size: 13px;
    color: #0d1115;
    font-weight: 700;
  }
  .dc-pdp-trust__item span {
    font-size: 11.5px;
    color: #6b7280;
  }
  @media (max-width: 700px) {
    .dc-pdp-trust { grid-template-columns: 1fr; }
  }

  /* Payment */
  .dc-pdp-payment {
    padding-top: 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .dc-pdp-payment__row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .dc-pdp-payment__lbl {
    font-size: 12px;
    color: #6b7280;
    font-weight: 600;
    width: 90px;
    flex: none;
  }
  .dc-pdp-payment__icons {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .dc-pdp-pay-chip,
  .dc-pdp-secure-chip {
    background: #ffffff;
    border: 1px solid #ececef;
    border-radius: 6px;
    height: 26px;
    padding: 0 10px;
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #2a3038;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  /* Sticky buy floating card */
  .dc-sticky-buy {
    position: fixed;
    bottom: 24px;
    right: 24px;
    background: #ffffff;
    border-radius: 22px;
    box-shadow: 0 24px 60px -20px rgba(13, 17, 21, 0.3), 0 4px 12px rgba(13, 17, 21, 0.08);
    border: 1px solid #ececef;
    padding: 14px 18px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 14px;
    align-items: center;
    width: 460px;
    max-width: calc(100vw - 48px);
    z-index: 80;
    animation: dc-sticky-pop 0.4s cubic-bezier(.2,.9,.3,1.1);
  }
  .dc-sticky-buy[hidden] { display: none; }
  @keyframes dc-sticky-pop {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .dc-sticky-buy__toggle {
    position: absolute;
    top: -12px;
    right: 16px;
    width: 26px;
    height: 26px;
    border-radius: 999px;
    background: #ffffff;
    border: 1px solid #ececef;
    display: grid;
    place-items: center;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
    color: #6b7280;
    cursor: pointer;
    transition: color 0.15s, transform 0.15s;
  }
  .dc-sticky-buy__toggle:hover { color: #0d1115; transform: scale(1.08); }
  .dc-sticky-buy__thumb {
    width: 56px;
    height: 56px;
    border-radius: 10px;
    background: #ececef;
    overflow: hidden;
    display: grid;
    place-items: center;
    padding: 6px;
  }
  .dc-sticky-buy__thumb img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    mix-blend-mode: multiply;
  }
  .dc-sticky-buy__meta { min-width: 0; }
  .dc-sticky-buy__title {
    font-size: 13.5px;
    font-weight: 600;
    color: #0d1115;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .dc-sticky-buy__price {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-top: 4px;
  }
  .dc-sticky-buy__strike {
    font-size: 12px;
    color: #9ca3af;
    text-decoration: line-through;
  }
  .dc-sticky-buy__now {
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
    font-weight: 700;
    font-size: 17px;
    color: #0d1115;
    letter-spacing: -0.02em;
  }
  .dc-sticky-buy__add {
    background: #0d1115;
    color: #ffffff;
    border: 0;
    border-radius: 999px;
    padding: 11px 18px;
    font-size: 13px;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.18s, transform 0.18s;
    white-space: nowrap;
  }
  .dc-sticky-buy__add:hover { background: #16a34a; transform: translateY(-1px); }
  @media (max-width: 920px) {
    .dc-sticky-buy { width: auto; left: 12px; right: 12px; bottom: 12px; }
  }

  /* Description editorial */
  .dc-pdp-desc {
    background: #fafbfc;
    padding-block: 56px;
  }
  .dc-pdp-desc__container {
    max-width: 1320px;
    margin: 0 auto;
    padding-inline: 28px;
  }
  .dc-pdp-desc__head {
    text-align: center;
    margin-bottom: 32px;
  }
  .dc-pdp-desc__eyebrow {
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #6b7280;
    font-weight: 600;
    display: inline-block;
    margin-bottom: 8px;
  }
  .dc-pdp-desc__title {
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
    font-size: 44px;
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.025em;
    color: #0d1115;
    margin: 0;
  }
  .dc-pdp-desc__subtitle {
    font-size: 17px;
    color: #6b7280;
    margin: 12px auto 0;
    max-width: 60ch;
  }
  .dc-pdp-desc__body {
    max-width: 80ch;
    margin: 0 auto;
    font-size: 15.5px;
    line-height: 1.65;
    color: #2a3038;
  }
  .dc-pdp-desc__body p { margin: 0 0 14px; }
  .dc-pdp-desc__body h2,
  .dc-pdp-desc__body h3 {
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
    margin-top: 28px;
    margin-bottom: 12px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "DropChina PDP",
  "tag": "section",
  "class": "section-dc-pdp",
  "settings": [
    { "type": "text", "id": "subtitle", "label": "Subtítulo (linha abaixo do título)" },
    { "type": "text", "id": "desc_subtitle", "label": "Subtítulo bloco descrição" },
    { "type": "header", "content": "Frete por CEP (estimativa)" },
    { "type": "checkbox", "id": "show_cep", "label": "Exibir calculadora de frete", "default": true },
    { "type": "text", "id": "ship_zone_1", "label": "Zona 1 — Sudeste/Sul (Nome|Frete|Prazo)", "default": "Sudeste e Sul|A partir de R$ 19,90|2 a 5 dias úteis" },
    { "type": "text", "id": "ship_zone_2", "label": "Zona 2 — Centro-Oeste/Nordeste", "default": "Centro-Oeste e Nordeste|A partir de R$ 24,90|4 a 8 dias úteis" },
    { "type": "text", "id": "ship_zone_3", "label": "Zona 3 — Norte", "default": "Norte|A partir de R$ 29,90|6 a 12 dias úteis" },
    { "type": "text", "id": "ship_free_label", "label": "Linha de frete grátis", "default": "Frete grátis em compras acima de R$ 199" },
    { "type": "range", "id": "padding_top", "label": "Padding top breadcrumb→pdp", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 24 }
  ],
  "presets": [
    { "name": "DropChina PDP" }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}

  }

  /* Form fields */
  .dc-pdp-field { margin-bottom: 18px; }
  .dc-pdp-field__head {
    font-size: 13px;
    color: #2a3038;
    margin-bottom: 8px;
  }
  .dc-pdp-field__head b { color: #0d1115; font-weight: 700; }
  .dc-pdp-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

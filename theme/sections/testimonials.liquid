{% liquid
  assign color_scheme = section.settings.color_scheme | default: 'scheme-1'
  assign section_width = section.settings.section_width | default: 'page-width'
%}

<div class="section-background color-{{ color_scheme }}"></div>
<section
  class="section section--testimonials section--{{ section_width }} color-{{ color_scheme }}"
  style="padding-block-start: {{ section.settings.padding_top | default: 80 }}px; padding-block-end: {{ section.settings.padding_bottom | default: 80 }}px;"
>
  <div class="testimonials-wrapper">
    <div class="testimonials-head">
      <div class="testimonials-head__copy">
        {% if section.settings.eyebrow != blank %}
          <p class="testimonials-eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="testimonials-heading">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>
      <div class="testimonials-stats">
        <div class="testimonials-stat">
          <span class="testimonials-stat__num">{{ section.settings.stat_rating | default: '4,9' }}</span>
          <div class="testimonials-stat__stars" aria-hidden="true">★★★★★</div>
          <span class="testimonials-stat__lbl">Nota média</span>
        </div>
        <div class="testimonials-stat">
          <span class="testimonials-stat__num">{{ section.settings.stat_count | default: '12.480' }}</span>
          <span class="testimonials-stat__lbl">Compras avaliadas</span>
        </div>
        <div class="testimonials-stat">
          <span class="testimonials-stat__num">{{ section.settings.stat_recommend | default: '98%' }}</span>
          <span class="testimonials-stat__lbl">Recomendam a loja</span>
        </div>
      </div>
    </div>

    <div class="testimonials-grid">
      {% for block in section.blocks %}{% if block.type == 'testimonial' %}
        {%- liquid
          assign accent_colors = '#1f7a3a,#7c3aed,#d62828,#0e8aa5,#0891b2,#0f4fa8' | split: ','
          assign accent = accent_colors[forloop.index0] | default: '#1f7a3a'
          assign name_parts = block.settings.author | split: ' '
          assign first_initial = name_parts[0] | default: '?' | slice: 0, 1
          assign last_initial = ''
          if name_parts.size > 1
            assign last_initial = name_parts.last | slice: 0, 1
          endif
        -%}
        <article class="testimonial-card" {{ block.shopify_attributes }}>
          <header class="testimonial-card__head">
            <div class="testimonial-card__avatar" style="background:{{ accent }};" aria-hidden="true">
              {{ first_initial | upcase }}{{ last_initial | upcase }}
            </div>
            <div class="testimonial-card__author-info">
              <div class="testimonial-card__name">
                {{ block.settings.author }}
                <span class="testimonial-card__verified" title="Compra verificada" aria-label="Compra verificada">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M5 12l5 5L20 7"/></svg>
                </span>
              </div>
              {% if block.settings.title != blank %}
                <div class="testimonial-card__role">{{ block.settings.title }}</div>
              {% endif %}
            </div>
          </header>
          <div class="testimonial-card__rating" aria-label="{{ block.settings.rating }} de 5 estrelas">
            {%- assign rating = block.settings.rating | default: 5 | times: 1 -%}
            <span class="testimonial-card__stars">
              {%- for i in (1..5) -%}{%- if i <= rating -%}★{%- else -%}☆{%- endif -%}{%- endfor -%}
            </span>
            {% if block.settings.date != blank %}
              <span class="testimonial-card__date">· {{ block.settings.date }}</span>
            {% endif %}
          </div>
          {% if block.settings.quote != blank %}
            <p class="testimonial-card__quote">"{{ block.settings.quote }}"</p>
          {% endif %}
          <div class="testimonial-card__actions">
            <button type="button" class="testimonial-card__action">
              <span aria-hidden="true">👍</span> Útil
            </button>
            <button type="button" class="testimonial-card__action">
              <span aria-hidden="true">💬</span> Comentar
            </button>
          </div>
        </article>
      {% endif %}{% endfor %}
    </div>

    {%- assign platform_blocks = section.blocks | where: 'type', 'platform' -%}
    {%- if platform_blocks.size > 0 or section.settings.show_platforms -%}
      <div class="testimonials-platforms">
        <div class="testimonials-platforms__list">
          {%- for block in platform_blocks -%}
            {%- assign p_slug = block.settings.name | downcase | strip -%}
            {%- assign p_class = 'generic' -%}
            {%- if p_slug contains 'reclame' -%}{%- assign p_class = 'reclame' -%}
            {%- elsif p_slug contains 'google' -%}{%- assign p_class = 'google' -%}
            {%- elsif p_slug contains 'mercado' -%}{%- assign p_class = 'mercado' -%}
            {%- endif -%}
            <span class="testimonials-platforms__item testimonials-platforms__item--{{ p_class }}" {{ block.shopify_attributes }}>
              <span class="testimonials-platforms__chip testimonials-platforms__chip--{{ p_class }}">
                {%- case p_class -%}
                  {%- when 'reclame' -%}Reclame<b>AQUI</b>
                  {%- when 'google' -%}<svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09Z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23Z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22 .81-.62Z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38Z"/></svg>
                  {%- when 'mercado' -%}<span class="testimonials-platforms__chip-text">Mercado Livre</span>
                  {%- else -%}<b>{{ block.settings.name | escape }}</b>
                {%- endcase -%}
              </span>
              {%- if block.settings.value != blank or block.settings.subtitle != blank -%}
                <span class="testimonials-platforms__value">
                  {%- if block.settings.value != blank -%}
                    <span class="testimonials-platforms__value-title">{{ block.settings.value | escape }}</span>
                  {%- endif -%}
                  {%- if block.settings.subtitle != blank -%}
                    <span class="testimonials-platforms__value-sub">{{ block.settings.subtitle | escape }}</span>
                  {%- endif -%}
                </span>
              {%- endif -%}
            </span>
          {%- endfor -%}
        </div>
        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_link | default: '#' }}" class="testimonials-platforms__cta">
            {{ section.settings.cta_label | escape }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .section--testimonials {
    background: #fafbfc;
  }
  .section--testimonials .testimonials-wrapper {
    max-width: 1320px;
    margin-inline: auto;
    padding-inline: 28px;
  }
  .testimonials-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 40px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }
  .testimonials-head__copy { flex: 1; min-width: 280px; }
  .testimonials-eyebrow {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #6b7280;
    margin: 0 0 10px;
  }
  .testimonials-heading {
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
    font-size: clamp(2rem, 3vw, 2.75rem);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.025em;
    color: #0d1115;
    margin: 0;
    max-width: 22ch;
  }
  /* Card escuro de stats — destaque visual igual referência */
  .testimonials-stats {
    background: #0d1115;
    color: #ffffff;
    border-radius: 22px;
    padding: 22px 28px;
    display: inline-flex;
    gap: 40px;
    align-items: flex-end;
  }
  .testimonials-stat {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }
  .testimonials-stat__num {
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #ffffff;
    line-height: 1;
  }
  .testimonials-stat__stars {
    color: #f5c518;
    font-size: 13px;
    letter-spacing: 1px;
    margin-top: 4px;
  }
  .testimonials-stat__lbl {
    font-size: 12px;
    color: #9ca3af;
    margin-top: 6px;
  }

  /* Grid 3-col com cards brancos */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  @media (max-width: 920px) {
    .testimonials-grid { grid-template-columns: 1fr; }
    .testimonials-stats { gap: 18px; }
    .testimonials-stat__num { font-size: 24px; }
  }

  .testimonial-card {
    background: #ffffff;
    border-radius: 22px;
    border: 1px solid #ececef;
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: transform 0.18s, box-shadow 0.18s;
  }
  .testimonial-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 40px -16px rgba(20, 22, 24, 0.18);
  }

  .testimonial-card__head {
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .testimonial-card__avatar {
    width: 44px;
    height: 44px;
    border-radius: 999px;
    background: #1f7a3a;
    color: white;
    display: grid;
    place-items: center;
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.02em;
    flex: none;
  }
  .testimonial-card__author-info { min-width: 0; flex: 1; }
  .testimonial-card__name {
    font-size: 14.5px;
    font-weight: 700;
    color: #0d1115;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .testimonial-card__verified {
    width: 16px;
    height: 16px;
    border-radius: 999px;
    background: #22c55e;
    color: white;
    display: inline-grid;
    place-items: center;
    flex: none;
  }
  .testimonial-card__verified svg { width: 10px; height: 10px; }
  .testimonial-card__role {
    font-size: 12.5px;
    color: #6b7280;
    margin-top: 2px;
  }

  .testimonial-card__rating {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12.5px;
    color: #6b7280;
  }
  .testimonial-card__stars {
    color: #f1a900;
    font-size: 14px;
    letter-spacing: 1px;
  }
  .testimonial-card__date {
    color: #9ca3af;
    font-size: 12.5px;
  }

  .testimonial-card__quote {
    font-size: 14.5px;
    line-height: 1.55;
    color: #2a3038;
    margin: 0;
  }

  .testimonial-card__actions {
    display: flex;
    gap: 6px;
    margin-top: 4px;
    padding-top: 14px;
    border-top: 1px solid #ececef;
  }
  .testimonial-card__action {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: transparent;
    border: 0;
    padding: 4px 8px;
    border-radius: 999px;
    color: #6b7280;
    font-size: 12.5px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .testimonial-card__action:hover {
    background: #f4f5f7;
    color: #0d1115;
  }

  /* Reviews platforms strip (Reclame Aqui / Google / Mercado Livre) */
  .testimonials-platforms {
    margin-top: 32px;
    background: #ffffff;
    border: 1px solid #ececef;
    border-radius: 22px;
    padding: 24px 36px;
    display: flex;
    justify-content: space-between;
    align-items: stretch;
    gap: 24px;
    flex-wrap: wrap;
  }
  .testimonials-platforms__list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    flex: 1;
    align-items: center;
  }
  .testimonials-platforms__item {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    padding: 4px 28px;
    min-height: 50px;
    border-left: 1px solid #ececef;
    flex-direction: row;
    justify-content: flex-start;
  }
  .testimonials-platforms__item:first-child { border-left: 0; padding-left: 0; }
  .testimonials-platforms__chip { flex: none; }
  .testimonials-platforms__value {
    display: flex;
    flex-direction: column;
    gap: 2px;
    color: #6b7280;
    font-size: 13px;
    line-height: 1.3;
  }
  .testimonials-platforms__value-title {
    color: #0d1115;
    font-weight: 600;
    font-size: 14.5px;
  }
  .testimonials-platforms__value-sub {
    color: #9ca3af;
    font-size: 12.5px;
    font-weight: 500;
  }
  .testimonials-platforms__dot { display: none; }
  @media (max-width: 920px) {
    .testimonials-platforms__list {
      grid-template-columns: 1fr;
      gap: 12px;
    }
    .testimonials-platforms__item {
      border-left: 0;
      border-top: 1px solid #ececef;
      padding: 14px 0 0;
    }
    .testimonials-platforms__item:first-child { border-top: 0; padding-top: 0; }
  }

  /* Brand chips */
  .testimonials-platforms__chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 12.5px;
    font-weight: 600;
    line-height: 1;
  }
  .testimonials-platforms__chip--reclame {
    background: #00a859;
    color: #ffffff;
    letter-spacing: -0.01em;
    padding: 6px 12px;
    font-weight: 500;
  }
  .testimonials-platforms__chip--reclame b { color: #ffffff; font-weight: 800; }
  .testimonials-platforms__chip--google {
    background: #ffffff;
    border: 1px solid #ececef;
    color: #5f6368;
    font-family: "Manrope", sans-serif;
    font-weight: 500;
    gap: 6px;
    padding: 6px 12px;
  }
  .testimonials-platforms__chip--google::after {
    content: "Google";
    font-weight: 500;
  }
  .testimonials-platforms__chip--mercado {
    background: #fff159;
    color: #0d1115;
    font-weight: 600;
    padding: 6px 12px;
  }
  .testimonials-platforms__chip--mercado .testimonials-platforms__chip-text {
    font-weight: 600;
  }
  .testimonials-platforms__chip--generic b { color: #0d1115; font-weight: 700; }

  .testimonials-platforms__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0 18px;
    height: 40px;
    border-radius: 999px;
    border: 1px solid #d9dade;
    color: #0d1115;
    font-weight: 600;
    font-size: 13.5px;
    text-decoration: none;
    background: #ffffff;
    transition: all 0.18s;
  }
  .testimonials-platforms__cta:hover {
    background: #0d1115;
    color: #ffffff;
    border-color: #0d1115;
  }

  /* Cards com hover sutil + sombra */
  .testimonial-card {
    box-shadow: 0 1px 2px rgba(20, 22, 24, 0.04);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-wrapper section-wrapper--testimonials",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "AVALIAÇÕES VERIFICADAS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "4,9 / 5 em mais de 12 mil compras"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo (não usado no novo layout)"
    },
    {
      "type": "header",
      "content": "Stats agregados"
    },
    {
      "type": "text",
      "id": "stat_rating",
      "label": "Nota média",
      "default": "4,9"
    },
    {
      "type": "text",
      "id": "stat_count",
      "label": "Compras avaliadas",
      "default": "12.480"
    },
    {
      "type": "text",
      "id": "stat_recommend",
      "label": "% Recomendam",
      "default": "98%"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Largura da seção",
      "options": [
        { "value": "full-width", "label": "Largura total" },
        { "value": "page-width", "label": "Largura da página" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Esquema de cor",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding topo",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding base",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Plataformas de avaliação"
    },
    {
      "type": "checkbox",
      "id": "show_platforms",
      "label": "Exibir strip de plataformas",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA do strip",
      "default": "Ver todas as avaliações"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Depoimento",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Estrelas",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "title",
          "label": "Subtítulo (ex: Comprou Toner Evolut)",
          "default": "Comprou produto"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Depoimento",
          "default": "Recebi rápido, exatamente como descrito. Recomendo!"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Nome do autor",
          "default": "Cliente DropChina"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Data relativa (ex: há 3 dias)"
        }
      ]
    },
    {
      "type": "platform",
      "name": "Plataforma de avaliação",
      "settings": [
        { "type": "text", "id": "name", "label": "Nome", "default": "Reclame Aqui" },
        { "type": "text", "id": "value", "label": "Título (linha 1)", "default": "Reputação ótima" },
        { "type": "text", "id": "subtitle", "label": "Subtítulo (linha 2)", "default": "8.2 / 10" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "platform", "settings": { "name": "Reclame Aqui", "value": "Reputação ótima" } },
        { "type": "platform", "settings": { "name": "Google", "value": "4,8 (3.214 avaliações)" } },
        { "type": "platform", "settings": { "name": "Mercado Livre", "value": "MercadoLíder Platinum" } }
      ]
    }
  ]
}
{% endschema %}

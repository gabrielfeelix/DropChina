{% liquid
  assign color_scheme = section.settings.color_scheme | default: 'scheme-1'
  assign section_width = section.settings.section_width | default: 'page-width'
%}

<div class="section-background color-{{ color_scheme }}"></div>
<section
  class="section section--testimonials section--{{ section_width }} color-{{ color_scheme }}"
  style="padding-block-start: {{ section.settings.padding_top | default: 64 }}px; padding-block-end: {{ section.settings.padding_bottom | default: 64 }}px;"
>
  <div class="testimonials-wrapper">
    {% if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank %}
      <header class="testimonials-header">
        {% if section.settings.eyebrow != blank %}
          <p class="testimonials-eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="testimonials-heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="testimonials-subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </header>
    {% endif %}

    <div class="testimonials-grid">
      {% for block in section.blocks %}
        <article class="testimonial-card" {{ block.shopify_attributes }}>
          <div class="testimonial-card__rating" aria-label="{{ block.settings.rating }} de 5 estrelas">
            {% assign rating = block.settings.rating | default: 5 | times: 1 %}
            {% for i in (1..5) %}{% if i <= rating %}★{% else %}☆{% endif %}{% endfor %}
          </div>
          {% if block.settings.title != blank %}
            <h3 class="testimonial-card__title">{{ block.settings.title }}</h3>
          {% endif %}
          {% if block.settings.quote != blank %}
            <p class="testimonial-card__quote">{{ block.settings.quote }}</p>
          {% endif %}
          <div class="testimonial-card__author">
            <span class="testimonial-card__avatar" aria-hidden="true">
              {{ block.settings.author | default: '?' | slice: 0, 1 }}
            </span>
            <span class="testimonial-card__name">{{ block.settings.author }}</span>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .section--testimonials .testimonials-wrapper {
    max-width: var(--page-width, 1440px);
    margin-inline: auto;
    padding-inline: clamp(16px, 4vw, 64px);
  }

  .testimonials-header {
    margin-bottom: 32px;
  }

  .testimonials-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #6b7280;
    margin-bottom: 8px;
  }

  .testimonials-heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--color-foreground-heading);
    margin-bottom: 8px;
  }

  .testimonials-subheading {
    font-size: 1rem;
    color: #6b7280;
    margin: 0;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 600px) {
    .testimonials-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1000px) {
    .testimonials-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-wrapper section-wrapper--testimonials",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "AVALIAÇÕES"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "O que nossos clientes dizem"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Mais de 50 mil clientes já confiaram na DropChina."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Largura da seção",
      "options": [
        { "value": "full-width", "label": "Largura total" },
        { "value": "page-width", "label": "Largura da página" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Esquema de cor",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding topo",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding base",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Depoimento",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Estrelas",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título do review",
          "default": "Excelente atendimento"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Depoimento",
          "default": "Recebi rápido, exatamente como descrito. Recomendo!"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Nome do autor",
          "default": "Cliente DropChina"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "title": "Excelente",
            "quote": "Recebi em 3 dias, embalagem perfeita.",
            "author": "Maria S."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "title": "Recomendo",
            "quote": "Atendimento rápido pelo WhatsApp.",
            "author": "João P."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 4,
            "title": "Ótimo custo",
            "quote": "Toner compatível funcionou perfeitamente.",
            "author": "Carlos M."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "title": "Confiável",
            "quote": "Já é a quarta vez que compro aqui.",
            "author": "Ana B."
          }
        }
      ]
    }
  ]
}
{% endschema %}

<div class="dc-cart" data-dc-cart hidden aria-hidden="true">
  <div class="dc-cart__backdrop" data-dc-cart-close></div>
  <aside class="dc-cart__panel" role="dialog" aria-modal="true" aria-labelledby="dc-cart-title">
    {%- liquid
      assign free_threshold = section.settings.free_shipping_threshold | default: 19900
      assign cart_total = cart.total_price
      assign missing = free_threshold | minus: cart_total
      if missing < 0
        assign missing = 0
      endif
      assign progress = 0
      if free_threshold > 0
        assign progress = cart_total | times: 100 | divided_by: free_threshold
        if progress > 100
          assign progress = 100
        endif
      endif
      assign discount_code = section.settings.discount_code | default: 'DROP10'
      assign discount_pct  = section.settings.discount_pct  | default: 10
      assign discount_amount = cart_total | times: discount_pct | divided_by: 100
      assign pix_total = cart_total | minus: discount_amount
      assign installments_n = section.settings.installments | default: 12
      assign installment_val = 0
      if installments_n > 0
        assign installment_val = cart_total | divided_by: installments_n
      endif
    -%}

    <header class="dc-cart__head">
      <div>
        <h2 id="dc-cart-title" class="dc-cart__title">Seu carrinho</h2>
        <p class="dc-cart__count">{{ cart.item_count }} {% if cart.item_count == 1 %}item{% else %}itens{% endif %}</p>
      </div>
      <button type="button" class="dc-cart__close" aria-label="Fechar carrinho" data-dc-cart-close>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </header>

    {%- if cart.item_count > 0 -%}
      <div class="dc-cart__shipping">
        {%- if missing > 0 -%}
          <p class="dc-cart__shipping-msg">
            Faltam <b>{{ missing | money }}</b> para <b>frete grátis</b>
          </p>
        {%- else -%}
          <p class="dc-cart__shipping-msg dc-cart__shipping-msg--won">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Você ganhou <b>frete grátis</b>!
          </p>
        {%- endif -%}
        <div class="dc-cart__progress">
          <span class="dc-cart__progress-fill" style="width: {{ progress }}%;"></span>
        </div>
      </div>
    {%- endif -%}

    <div class="dc-cart__body">
      {%- if cart.item_count == 0 -%}
        <div class="dc-cart__empty">
          <div class="dc-cart__empty-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 4h2l2.5 12.5a2 2 0 0 0 2 1.5h8a2 2 0 0 0 2-1.5L21 8H6"/><circle cx="10" cy="21" r="1.4"/><circle cx="17" cy="21" r="1.4"/></svg>
          </div>
          <h3>Seu carrinho está vazio</h3>
          <p>Adicione produtos pra começar.</p>
          <a href="{{ routes.collections_url }}" class="dc-cart__empty-cta">Ver produtos</a>
        </div>
      {%- else -%}
        <ul class="dc-cart__list" data-dc-cart-list>
          {%- for item in cart.items -%}
            <li class="dc-cart__item" data-line="{{ forloop.index }}" data-key="{{ item.key }}">
              <a href="{{ item.url }}" class="dc-cart__item-art">
                {%- if item.image -%}
                  {{ item.image | image_url: width: 160 | image_tag: alt: item.title, loading: 'lazy', class: 'dc-cart__item-img' }}
                {%- endif -%}
              </a>
              <div class="dc-cart__item-info">
                <div class="dc-cart__item-brand">{{ item.product.vendor | escape }}</div>
                <a href="{{ item.url }}" class="dc-cart__item-title">{{ item.product.title | escape }}</a>
                {%- unless item.product.has_only_default_variant -%}
                  <div class="dc-cart__item-variant">{{ item.variant.title | escape }}</div>
                {%- endunless -%}
                <div class="dc-cart__item-row">
                  <div class="dc-cart__qty" data-dc-qty>
                    <button type="button" class="dc-cart__qty-btn" data-dc-qty-dec aria-label="Diminuir">−</button>
                    <input
                      type="number"
                      min="0"
                      class="dc-cart__qty-input"
                      value="{{ item.quantity }}"
                      data-line="{{ forloop.index }}"
                      data-dc-qty-input
                      aria-label="Quantidade"
                    >
                    <button type="button" class="dc-cart__qty-btn" data-dc-qty-inc aria-label="Aumentar">+</button>
                  </div>
                  <div class="dc-cart__item-price">{{ item.final_line_price | money }}</div>
                </div>
              </div>
              <button type="button" class="dc-cart__item-remove" data-dc-qty-remove aria-label="Remover">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M6 6l1 14a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2l1-14"/></svg>
              </button>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    {%- if cart.item_count > 0 -%}
      <footer class="dc-cart__footer">
        {%- if discount_code != blank -%}
          <div class="dc-cart__coupon">
            <span class="dc-cart__coupon-label">Cupom</span>
            <span class="dc-cart__coupon-code">{{ discount_code | escape }}</span>
            <span class="dc-cart__coupon-off">aplicado no checkout ✓</span>
          </div>
        {%- endif -%}

        <dl class="dc-cart__totals">
          <div class="dc-cart__totals-row">
            <dt>Subtotal</dt>
            <dd>{{ cart_total | money }}</dd>
          </div>
          <div class="dc-cart__totals-row dc-cart__totals-row--pix">
            <dt>No Pix ({{ discount_pct }}% OFF)</dt>
            <dd>{{ pix_total | money }}</dd>
          </div>
          <div class="dc-cart__totals-row dc-cart__totals-row--installments">
            <dt>ou em até</dt>
            <dd><b>{{ installments_n }}x {{ installment_val | money }}</b> <span>sem juros</span></dd>
          </div>
        </dl>

        {%- comment -%} /discount/CODE aplica o cupom de verdade na sessão antes do checkout {%- endcomment -%}
        {%- if discount_code != blank -%}
          {%- assign checkout_url = '/discount/' | append: discount_code | append: '?redirect=/checkout' -%}
        {%- else -%}
          {%- assign checkout_url = '/checkout' -%}
        {%- endif -%}
        <a href="{{ checkout_url }}" class="dc-cart__checkout">
          Finalizar compra
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
        </a>
        <button type="button" class="dc-cart__continue" data-dc-cart-close>Continuar comprando</button>

        <ul class="dc-cart__badges">
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 4 6v6c0 4.5 3.4 8.4 8 9 4.6-.6 8-4.5 8-9V6l-8-3Z"/><path d="m9 12 2 2 4-4"/></svg>
            Compra 100% segura
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h11v9H3z"/><path d="M14 10h4l3 3v3h-7z"/><circle cx="7" cy="18" r="1.6"/><circle cx="17" cy="18" r="1.6"/></svg>
            Envio em 24h
          </li>
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 15.5-6.3L21 8"/><path d="M21 4v4h-4"/><path d="M21 12a9 9 0 0 1-15.5 6.3L3 16"/><path d="M3 20v-4h4"/></svg>
            7 dias para troca
          </li>
        </ul>
      </footer>
    {%- endif -%}
  </aside>
</div>

<script>
(function() {
  var cart = document.querySelector('[data-dc-cart]');
  if (!cart) return;
  // Move o cart pra <body> pra escapar do stacking context do #header-group
  // (que tem backdrop-filter e prende position:fixed dentro).
  if (cart.parentElement !== document.body) {
    document.body.appendChild(cart);
  }
  var panel = cart.querySelector('.dc-cart__panel');
  var body = document.body;
  var lastFocus = null;

  function open() {
    lastFocus = document.activeElement;
    cart.hidden = false;
    cart.setAttribute('aria-hidden', 'false');
    requestAnimationFrame(function() {
      cart.classList.add('is-open');
    });
    body.style.overflow = 'hidden';
    var closeBtn = cart.querySelector('.dc-cart__close');
    if (closeBtn) closeBtn.focus();
  }
  function close() {
    cart.classList.remove('is-open');
    cart.setAttribute('aria-hidden', 'true');
    body.style.overflow = '';
    setTimeout(function() { cart.hidden = true; }, 240);
    if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
  }

  // Triggers (cart icon no header + qualquer [data-dc-cart-trigger])
  document.addEventListener('click', function(e) {
    var trigger = e.target.closest('[data-dc-cart-trigger]');
    if (trigger) {
      e.preventDefault();
      open();
      return;
    }
    var closer = e.target.closest('[data-dc-cart-close]');
    if (closer && cart.contains(closer)) {
      e.preventDefault();
      close();
    }
  });

  // ESC
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !cart.hidden) close();
  });

  // Abre depois de adicionar ao carrinho (eventos custom + listener AJAX)
  document.addEventListener('cart:add', function() { open(); });
  document.addEventListener('dc:cart:open', function() { open(); });

  // Quantity controls
  function update(line, qty) {
    return fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ line: line, quantity: qty })
    }).then(function(r) { return r.json(); }).then(function(data) {
      // reload section dc-cart-sidedrawer
      return fetch(window.location.pathname + '?section_id={{ section.id }}', { headers: { 'Accept': 'text/html' } })
        .then(function(r) { return r.text(); })
        .then(function(html) {
          var temp = document.createElement('div');
          temp.innerHTML = html;
          var fresh = temp.querySelector('[data-dc-cart]');
          if (fresh) {
            cart.querySelector('.dc-cart__panel').innerHTML = fresh.querySelector('.dc-cart__panel').innerHTML;
          }
          // dispatch update for header badge
          document.dispatchEvent(new CustomEvent('cart:update', { detail: { resource: data } }));
          var badges = document.querySelectorAll('[data-dc-cart-count]');
          badges.forEach(function(b) {
            b.textContent = data.item_count;
            b.hidden = data.item_count === 0;
          });
        });
    });
  }

  cart.addEventListener('click', function(e) {
    var inc = e.target.closest('[data-dc-qty-inc]');
    var dec = e.target.closest('[data-dc-qty-dec]');
    var rm  = e.target.closest('[data-dc-qty-remove]');
    if (!inc && !dec && !rm) return;
    e.preventDefault();
    var item = e.target.closest('[data-line]');
    if (!item) return;
    var line = parseInt(item.dataset.line, 10);
    if (rm) { update(line, 0); return; }
    var input = item.querySelector('[data-dc-qty-input]');
    var cur = parseInt(input.value, 10) || 1;
    var next = inc ? cur + 1 : Math.max(0, cur - 1);
    update(line, next);
  });

  cart.addEventListener('change', function(e) {
    var input = e.target.closest('[data-dc-qty-input]');
    if (!input) return;
    var line = parseInt(input.dataset.line, 10);
    var qty = Math.max(0, parseInt(input.value, 10) || 0);
    update(line, qty);
  });

  // expose pra debug
  window.dcCart = { open: open, close: close };
})();
</script>

{% stylesheet %}
  .dc-cart[hidden] { display: none; }
  .dc-cart {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    justify-content: flex-end;
  }
  .dc-cart__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(13, 17, 21, 0.45);
    opacity: 0;
    transition: opacity 0.24s ease;
  }
  .dc-cart.is-open .dc-cart__backdrop { opacity: 1; }
  .dc-cart__panel {
    position: relative;
    width: min(440px, 100vw);
    max-width: 100%;
    height: 100vh;
    background: #ffffff;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.28s cubic-bezier(0.32, 0.72, 0, 1);
    box-shadow: -24px 0 60px -20px rgba(13, 17, 21, 0.25);
  }
  .dc-cart.is-open .dc-cart__panel { transform: translateX(0); }

  .dc-cart__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 24px 24px 18px;
    border-bottom: 1px solid #ececef;
    flex: none;
  }
  .dc-cart__title {
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: #0d1115;
    margin: 0;
    letter-spacing: -0.015em;
  }
  .dc-cart__count {
    font-size: 13px;
    color: #6b7280;
    margin: 2px 0 0;
  }
  .dc-cart__close {
    width: 36px;
    height: 36px;
    border-radius: 999px;
    background: #f4f5f7;
    border: 0;
    display: grid;
    place-items: center;
    cursor: pointer;
    color: #0d1115;
    transition: background 0.15s, color 0.15s;
    flex: none;
  }
  .dc-cart__close:hover {
    background: #0d1115;
    color: #ffffff;
  }

  .dc-cart__shipping {
    padding: 16px 24px 14px;
    border-bottom: 1px solid #ececef;
    background: #fafbfc;
    flex: none;
  }
  .dc-cart__shipping-msg {
    margin: 0 0 10px;
    font-size: 13.5px;
    color: #2a3038;
  }
  .dc-cart__shipping-msg b { font-weight: 700; color: #0d1115; }
  .dc-cart__shipping-msg--won {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #15803d;
  }
  .dc-cart__shipping-msg--won svg { color: #15803d; }
  .dc-cart__progress {
    height: 6px;
    border-radius: 999px;
    background: #e5e7eb;
    overflow: hidden;
  }
  .dc-cart__progress-fill {
    display: block;
    height: 100%;
    background: linear-gradient(90deg, #15803d, #16a34a);
    transition: width 0.4s ease;
  }

  .dc-cart__body {
    flex: 1;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 8px 24px 24px;
  }
  .dc-cart__empty {
    text-align: center;
    padding: 56px 16px 32px;
  }
  .dc-cart__empty-icon {
    width: 72px;
    height: 72px;
    margin: 0 auto 16px;
    border-radius: 999px;
    background: #f4f5f7;
    color: #6b7280;
    display: grid;
    place-items: center;
  }
  .dc-cart__empty h3 {
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: #0d1115;
    margin: 0 0 6px;
  }
  .dc-cart__empty p {
    font-size: 14px;
    color: #6b7280;
    margin: 0 0 22px;
  }
  .dc-cart__empty-cta {
    display: inline-flex;
    height: 44px;
    align-items: center;
    padding: 0 24px;
    border-radius: 999px;
    background: #0d1115;
    color: #ffffff;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    transition: background 0.15s;
  }
  .dc-cart__empty-cta:hover { background: #d62828; }

  .dc-cart__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .dc-cart__item {
    display: grid;
    grid-template-columns: 88px 1fr auto;
    gap: 14px;
    padding: 18px 0;
    border-bottom: 1px solid #ececef;
    position: relative;
  }
  .dc-cart__item:last-child { border-bottom: 0; }
  .dc-cart__item-art {
    width: 88px;
    height: 88px;
    border-radius: 12px;
    background: #ececef;
    display: grid;
    place-items: center;
    padding: 8px;
    overflow: hidden;
  }
  .dc-cart__item-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    mix-blend-mode: multiply;
  }
  .dc-cart__item-info {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .dc-cart__item-brand {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #6b7280;
    font-weight: 700;
  }
  .dc-cart__item-title {
    font-size: 14px;
    font-weight: 500;
    color: #0d1115;
    line-height: 1.35;
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .dc-cart__item-title:hover { color: #d62828; }
  .dc-cart__item-variant {
    font-size: 12px;
    color: #6b7280;
  }
  .dc-cart__item-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 8px;
    gap: 12px;
  }
  .dc-cart__qty {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    border: 1px solid #d9dade;
    border-radius: 999px;
    padding: 2px;
  }
  .dc-cart__qty-btn {
    width: 26px;
    height: 26px;
    border-radius: 999px;
    background: transparent;
    border: 0;
    color: #0d1115;
    font-size: 16px;
    line-height: 1;
    font-weight: 600;
    cursor: pointer;
    display: grid;
    place-items: center;
    font-family: inherit;
  }
  .dc-cart__qty-btn:hover { background: #f4f5f7; }
  .dc-cart__qty-input {
    width: 28px;
    height: 26px;
    border: 0;
    background: transparent;
    text-align: center;
    font-size: 13px;
    font-weight: 600;
    color: #0d1115;
    font-family: inherit;
    -moz-appearance: textfield;
    appearance: textfield;
  }
  .dc-cart__qty-input::-webkit-outer-spin-button,
  .dc-cart__qty-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  .dc-cart__item-price {
    font-weight: 700;
    font-size: 14.5px;
    color: #0d1115;
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
  }
  .dc-cart__item-remove {
    position: absolute;
    top: 18px;
    right: 0;
    width: 26px;
    height: 26px;
    border-radius: 999px;
    background: transparent;
    border: 0;
    color: #9ca3af;
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: color 0.15s, background 0.15s;
  }
  .dc-cart__item-remove:hover {
    background: #fef2f2;
    color: #d62828;
  }

  .dc-cart__footer {
    padding: 18px 24px 22px;
    border-top: 1px solid #ececef;
    background: #ffffff;
    flex: none;
  }
  .dc-cart__coupon {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    border: 1px dashed #0f4fa8;
    background: #fffaeb;
    border-radius: 12px;
    margin-bottom: 16px;
    font-size: 13.5px;
  }
  .dc-cart__coupon-label {
    font-weight: 600;
    color: #2a3038;
  }
  .dc-cart__coupon-code {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    border-radius: 6px;
    background: #0d1115;
    color: #ffffff;
    font-weight: 700;
    font-size: 11.5px;
    letter-spacing: 0.04em;
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
  }
  .dc-cart__coupon-off {
    margin-left: auto;
    font-weight: 700;
    color: #15803d;
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
  }
  .dc-cart__totals {
    margin: 0 0 16px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .dc-cart__totals-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 13.5px;
    color: #2a3038;
  }
  .dc-cart__totals-row dt, .dc-cart__totals-row dd { margin: 0; }
  .dc-cart__totals-row dd { font-weight: 700; color: #0d1115; font-family: "Bricolage Grotesque", "Manrope", sans-serif; }
  .dc-cart__totals-row--pix {
    font-size: 15px;
    padding-top: 4px;
  }
  .dc-cart__totals-row--pix dt {
    color: #0d1115;
    font-weight: 600;
  }
  .dc-cart__totals-row--pix dd {
    font-size: 22px;
    color: #15803d;
    font-weight: 700;
  }
  .dc-cart__totals-row--installments dt,
  .dc-cart__totals-row--installments dd {
    font-size: 12.5px;
    color: #6b7280;
    font-weight: 500;
  }
  .dc-cart__totals-row--installments dd b {
    color: #0d1115;
    font-weight: 700;
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
  }
  .dc-cart__totals-row--installments dd span { color: #6b7280; }

  .dc-cart__checkout {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    height: 54px;
    border-radius: 999px;
    background: #16a34a;
    color: #ffffff;
    text-decoration: none;
    font-weight: 700;
    font-size: 15.5px;
    letter-spacing: -0.005em;
    transition: background 0.18s, transform 0.18s;
    box-shadow: 0 8px 18px -8px rgba(22, 163, 74, 0.55);
  }
  .dc-cart__checkout:hover {
    background: #15803d;
    transform: translateY(-1px);
  }
  .dc-cart__continue {
    width: 100%;
    height: 44px;
    margin-top: 8px;
    border-radius: 999px;
    background: transparent;
    border: 0;
    color: #2a3038;
    font-weight: 500;
    font-size: 13.5px;
    cursor: pointer;
    font-family: inherit;
    transition: color 0.15s;
  }
  .dc-cart__continue:hover { color: #0d1115; text-decoration: underline; }

  .dc-cart__badges {
    list-style: none;
    padding: 14px 0 0;
    margin: 14px 0 0;
    border-top: 1px solid #ececef;
    display: flex;
    justify-content: space-between;
    gap: 8px;
  }
  .dc-cart__badges li {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11.5px;
    color: #6b7280;
    font-weight: 500;
  }
  .dc-cart__badges svg { color: #6b7280; flex: none; }

  @media (max-width: 480px) {
    .dc-cart__panel { width: 100vw; }
    .dc-cart__badges { flex-wrap: wrap; gap: 10px 16px; justify-content: flex-start; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "DC Cart Sidedrawer",
  "tag": "div",
  "settings": [
    { "type": "number", "id": "free_shipping_threshold", "label": "Limite frete grátis (em centavos)", "default": 19900, "info": "Ex: 19900 = R$ 199,00" },
    { "type": "text", "id": "discount_code", "label": "Cupom (código)", "default": "DROP10" },
    { "type": "range", "id": "discount_pct", "label": "Desconto Pix (%)", "min": 0, "max": 50, "step": 1, "default": 10 },
    { "type": "range", "id": "installments", "label": "Parcelas (sem juros)", "min": 1, "max": 18, "step": 1, "default": 12 }
  ]
}
{% endschema %}

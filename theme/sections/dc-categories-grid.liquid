<section class="dc-categories section section--page-width spacing-style" style="{% render 'spacing-padding', settings: section.settings %}">
  <div class="dc-categories__head">
    <div>
      <p class="dc-categories__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h2 class="dc-categories__title">{{ section.settings.heading | escape }}</h2>
    </div>
    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_link | default: '#' }}" class="dc-categories__cta-all">
        {{ section.settings.cta_label | escape }}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
      </a>
    {%- endif -%}
  </div>

  <div class="dc-categories__grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'category' -%}
        <a href="{{ block.settings.link | default: '#' }}" class="dc-cat" {{ block.shopify_attributes }}>
          <div class="dc-cat__art">
            {%- if block.settings.icon_svg != blank -%}
              {{ block.settings.icon_svg }}
            {%- else -%}
              <svg viewBox="0 0 160 140" width="100%" height="100%" aria-hidden="true">
                <ellipse cx="80" cy="124" rx="56" ry="6" fill="rgba(13,17,21,0.10)"/>
                <rect x="34" y="36" width="92" height="64" rx="6" fill="#2a3038"/>
                <rect x="44" y="58" width="40" height="34" rx="2" fill="#0e8aa5"/>
              </svg>
            {%- endif -%}
          </div>
          <div class="dc-cat__name">{{ block.settings.name | escape }}</div>
          {%- if block.settings.collection != blank -%}
            <div class="dc-cat__count">{{ block.settings.collection.products_count }} {% if block.settings.collection.products_count == 1 %}produto{% else %}produtos{% endif %}</div>
          {%- elsif block.settings.count != blank -%}
            <div class="dc-cat__count">{{ block.settings.count | escape }}</div>
          {%- endif -%}
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% stylesheet %}
  .dc-categories { padding-block: 56px; }
  .dc-categories__head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 28px;
  }
  .dc-categories__eyebrow {
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #6b7280;
    font-weight: 600;
    margin: 0 0 10px;
  }
  .dc-categories__title {
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
    font-size: 44px;
    line-height: 1.04;
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0;
    color: #0d1115;
  }
  .dc-categories__cta-all {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 40px;
    padding: 0 18px;
    border-radius: 999px;
    border: 1px solid #d9dade;
    color: #0d1115;
    font-weight: 600;
    font-size: 13.5px;
    text-decoration: none;
    transition: all 0.15s;
  }
  .dc-categories__cta-all:hover { border-color: #0d1115; background: #0d1115; color: #fff; }
  .dc-categories__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
  }
  .dc-cat {
    background: transparent;
    border: 1px solid transparent;
    border-radius: 22px;
    padding: 20px 12px 22px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-align: center;
    transition: transform 0.22s, background 0.22s, border-color 0.22s, box-shadow 0.22s;
    cursor: pointer;
    color: #0d1115;
    text-decoration: none;
  }
  .dc-cat:hover {
    transform: translateY(-3px);
    background: #fff;
    border-color: #ececef;
    box-shadow: 0 16px 36px -18px rgba(13, 17, 21, 0.18);
  }
  .dc-cat__art {
    width: 130px;
    height: 110px;
    margin-bottom: 6px;
    display: grid;
    place-items: center;
    transition: transform 0.3s ease;
  }
  .dc-cat:hover .dc-cat__art { transform: translateY(-2px) scale(1.04); }
  .dc-cat__name {
    font-weight: 600;
    font-size: 14px;
    color: #0d1115;
    letter-spacing: -0.01em;
    margin-top: 4px;
  }
  .dc-cat__count {
    font-size: 12px;
    color: #6b7280;
  }
  @media (max-width: 1100px) { .dc-categories__grid { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 700px) {
    .dc-categories__grid { grid-template-columns: repeat(3, 1fr); }
    .dc-categories__title { font-size: 30px; }
  }
{% endstylesheet %}

{% schema %}

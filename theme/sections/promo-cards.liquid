<section class="dc-promo-section" style="padding-block: {{ section.settings.padding_top | default: 48 }}px {{ section.settings.padding_bottom | default: 48 }}px;" aria-label="Compre por linha">
  <div class="dc-promo__container">
    {%- if section.settings.heading != blank or section.settings.eyebrow != blank -%}
      <div class="dc-promo__head">
        <div>
          {%- if section.settings.eyebrow != blank -%}
            <p class="dc-promo__eyebrow">{{ section.settings.eyebrow | escape }}</p>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="dc-promo__title">{{ section.settings.heading | escape }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_link | default: '#' }}" class="dc-promo__head-cta">
            {{ section.settings.cta_label | escape }}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="dc-promo__grid">
      {%- for block in section.blocks -%}
        {%- assign idx = forloop.index0 -%}
        {%- assign tone = block.settings.tone | default: 'light' -%}
        {%- assign has_bg = false -%}
        {%- if block.settings.background_asset != blank or block.settings.image != blank -%}
          {%- assign has_bg = true -%}
        {%- endif -%}
        <a
          href="{{ block.settings.link | default: '#' }}"
          class="dc-promo-card dc-promo-card--{{ tone }}{% if has_bg %} dc-promo-card--has-bg{% endif %}"
          data-idx="{{ idx }}"
          {{ block.shopify_attributes }}
          {%- if block.settings.background_asset != blank %} style="background-image: linear-gradient(180deg, rgba(13,17,21,0.05) 0%, rgba(13,17,21,0.35) 50%, rgba(13,17,21,0.85) 100%), url('{{ block.settings.background_asset | asset_url }}'); background-size: cover; background-position: center;"{% endif -%}
        >
          {%- if block.settings.background_asset == blank and block.settings.image != blank -%}
            {%- assign promo_alt = block.settings.title | default: shop.name | escape -%}
            <div class="dc-promo-card__image">
              {{ block.settings.image | image_url: width: 800 | image_tag:
                  loading: 'lazy',
                  alt: promo_alt,
                  widths: '400, 800',
                  sizes: '(max-width: 480px) 80vw, 50vw' }}
            </div>
          {%- endif -%}
          <div class="dc-promo-card__body">
            {%- if block.settings.eyebrow != blank -%}
              <p class="dc-promo-card__eyebrow">{{ block.settings.eyebrow | escape }}</p>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="dc-promo-card__title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.cta_label != blank -%}
              <span class="dc-promo-card__cta">
                {{ block.settings.cta_label | escape }}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
              </span>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .dc-promo-section { background: #ffffff; }
  .dc-promo__container {
    max-width: 1320px;
    margin: 0 auto;
    padding-inline: 28px;
  }
  .dc-promo__head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .dc-promo__eyebrow {
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #6b7280;
    font-weight: 600;
    margin: 0 0 10px;
  }
  .dc-promo__title {
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
    font-size: 40px;
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.025em;
    color: #0d1115;
    margin: 0;
  }
  .dc-promo__head-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 40px;
    padding: 0 18px;
    border-radius: 999px;
    border: 1px solid #d9dade;
    color: #0d1115;
    font-weight: 600;
    font-size: 13.5px;
    text-decoration: none;
    background: #ffffff;
    transition: all 0.18s;
  }
  .dc-promo__head-cta:hover {
    background: #0d1115;
    color: #ffffff;
    border-color: #0d1115;
  }

  /* BENTO GRID: coluna 1 hero (1.6fr 2 rows) + col 2-3 (1fr 1fr) */
  .dc-promo__grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    grid-template-rows: minmax(280px, auto) minmax(280px, auto);
    gap: 16px;
    min-height: 580px;
  }
  /* 1º card: ocupa coluna 1, 2 rows */
  .dc-promo__grid > .dc-promo-card:nth-child(1) {
    grid-column: 1;
    grid-row: 1 / 3;
  }
  /* 2º card: ocupa colunas 2-3, row 1 */
  .dc-promo__grid > .dc-promo-card:nth-child(2) {
    grid-column: 2 / 4;
    grid-row: 1;
  }
  /* 3º card: coluna 2, row 2 */
  .dc-promo__grid > .dc-promo-card:nth-child(3) {
    grid-column: 2;
    grid-row: 2;
  }
  /* 4º card: coluna 3, row 2 */
  .dc-promo__grid > .dc-promo-card:nth-child(4) {
    grid-column: 3;
    grid-row: 2;
  }

  .dc-promo-card {
    position: relative;
    border-radius: 28px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    isolation: isolate;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: #f4f5f7;
  }
  .dc-promo-card:hover { transform: translateY(-3px); }
  /* SEM degrade — textos pretos precisam contrastar com imagem clara */

  /* TONS */
  .dc-promo-card--light { background: #f4f5f7; color: #0d1115; }
  .dc-promo-card--white { background: #ffffff; color: #0d1115; border: 1px solid #ececef; }
  .dc-promo-card--dark { background: #0d1115; color: #ffffff; }
  .dc-promo-card--yellow {
    background: linear-gradient(135deg, #f5c518 0%, #e85d04 100%);
    color: #ffffff;
  }
  /* has-bg agora mantém texto preto (não white) — fundo já é a imagem */
  .dc-promo-card--has-bg { color: #0d1115; }

  /* Imagem (quando block tem image_picker) */
  .dc-promo-card__image {
    flex: 1;
    display: grid;
    place-items: center;
    padding: 8px;
    overflow: hidden;
  }
  .dc-promo-card__image img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    mix-blend-mode: multiply;
  }
  /* Quando o card é dark/yellow, não aplica multiply (perde contraste) */
  .dc-promo-card--dark .dc-promo-card__image img,
  .dc-promo-card--yellow .dc-promo-card__image img {
    mix-blend-mode: normal;
  }

  /* Corpo do card */
  .dc-promo-card__body {
    position: relative;
    z-index: 2;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  /* 1º card (hero): copy CENTRADA no topo + imagem no fundo
     (igual referência "Impressão com qualidade premium") */
  .dc-promo__grid > .dc-promo-card:nth-child(1) {
    justify-content: space-between;
  }
  .dc-promo__grid > .dc-promo-card:nth-child(1) .dc-promo-card__body {
    text-align: center;
    padding: 40px 32px 0;
    order: -1;
  }
  .dc-promo__grid > .dc-promo-card:nth-child(1) .dc-promo-card__image {
    align-self: end;
  }

  .dc-promo-card__eyebrow {
    font-size: 11.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
    opacity: 0.85;
    margin: 0 0 8px;
    color: inherit;
  }
  .dc-promo-card--light .dc-promo-card__eyebrow,
  .dc-promo-card--white .dc-promo-card__eyebrow { color: #6b7280; opacity: 1; }

  .dc-promo-card__title {
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
    font-size: 28px;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: inherit;
    margin: 0;
    max-width: 18ch;
  }
  /* Hero card título maior */
  .dc-promo__grid > .dc-promo-card:nth-child(1) .dc-promo-card__title {
    font-size: 38px;
    max-width: 16ch;
    margin: 0 auto;
  }
  /* Card 2 (Panini) título maior também */
  .dc-promo__grid > .dc-promo-card:nth-child(2) .dc-promo-card__title {
    font-size: 32px;
  }

  .dc-promo-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 14px;
    color: inherit;
    font-weight: 600;
    font-size: 14px;
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .dc-promo-card--light .dc-promo-card__cta,
  .dc-promo-card--white .dc-promo-card__cta { color: #d62828; text-decoration: none; }
  .dc-promo__grid > .dc-promo-card:nth-child(1) .dc-promo-card__cta {
    justify-content: center;
  }

  /* Responsive */
  @media (max-width: 920px) {
    .dc-promo__grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      min-height: auto;
    }
    .dc-promo__grid > .dc-promo-card:nth-child(1),
    .dc-promo__grid > .dc-promo-card:nth-child(2),
    .dc-promo__grid > .dc-promo-card:nth-child(3),
    .dc-promo__grid > .dc-promo-card:nth-child(4) {
      grid-column: auto;
      grid-row: auto;
      min-height: 240px;
    }
    .dc-promo__grid > .dc-promo-card:nth-child(1) .dc-promo-card__title { font-size: 28px; }
    .dc-promo__title { font-size: 30px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "DC Bento Promo",
  "tag": "section",
  "class": "section-dc-promo",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "EM DESTAQUE" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Compre por linha" },
    { "type": "text", "id": "cta_label", "label": "CTA do header", "default": "Ver todas" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48 }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card promocional",
      "limit": 4,
      "settings": [
        { "type": "select", "id": "tone", "label": "Tom do card", "options": [
          { "value": "light", "label": "Claro (cinza)" },
          { "value": "white", "label": "Branco (com border)" },
          { "value": "dark", "label": "Escuro (preto)" },
          { "value": "yellow", "label": "Amarelo/laranja (gradient)" }
        ], "default": "light" },
        { "type": "image_picker", "id": "image", "label": "Imagem do produto (contained)" },
        { "type": "text", "id": "background_asset", "label": "Background asset (theme/assets filename)", "info": "Ex: banner-toner.png. Card vira banner full-bg image-led." },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "EYEBROW" },
        { "type": "text", "id": "title", "label": "Título", "default": "Título do card" },
        { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Ver coleção" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Compre por linha (bento 2x2)",
      "blocks": [
        { "type": "card", "settings": { "tone": "light", "eyebrow": "CARTUCHOS & TONERS", "title": "Impressão com qualidade premium.", "cta_label": "Ver coleção" } },
        { "type": "card", "settings": { "tone": "dark", "eyebrow": "EDIÇÃO LIMITADA", "title": "Pacotes Panini World Cup 2026.", "cta_label": "Ver coleção" } },
        { "type": "card", "settings": { "tone": "yellow", "eyebrow": "SETUP GAMER", "title": "Placas de vídeo a partir de R$ 293", "cta_label": "Montar setup" } },
        { "type": "card", "settings": { "tone": "dark", "eyebrow": "BLACK WEEK", "title": "GPUs com até 25% OFF", "cta_label": "Ver ofertas" } }
      ]
    }
  ]
}
{% endschema %}

<section class="dc-trust-section" style="padding-block: {{ section.settings.padding_top | default: 28 }}px {{ section.settings.padding_bottom | default: 28 }}px;">
  <div class="dc-trust__container">
    {%- for block in section.blocks -%}
      <div class="dc-trust__item" {{ block.shopify_attributes }}>
        <div class="dc-trust__icon">
          {%- case block.settings.icon -%}
            {%- when 'truck' -%}<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h11v9H3z"/><path d="M14 10h4l3 3v3h-7z"/><circle cx="7" cy="18" r="1.6"/><circle cx="17" cy="18" r="1.6"/></svg>
            {%- when 'shield' -%}<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 4 6v6c0 4.5 3.4 8.4 8 9 4.6-.6 8-4.5 8-9V6l-8-3Z"/><path d="m9 12 2 2 4-4"/></svg>
            {%- when 'refresh' -%}<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 15.5-6.3L21 8"/><path d="M21 4v4h-4"/><path d="M21 12a9 9 0 0 1-15.5 6.3L3 16"/><path d="M3 20v-4h4"/></svg>
            {%- when 'headset' -%}<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 13a8 8 0 0 1 16 0v4a2 2 0 0 1-2 2h-2v-6h4"/><path d="M4 13v4a2 2 0 0 0 2 2h2v-6H4"/></svg>
            {%- when 'lock' -%}<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
            {%- else -%}<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 13.5 9 21 10.5 13.5 12 12 19 10.5 12 3 10.5 10.5 9 12 2Z"/></svg>
          {%- endcase -%}
        </div>
        <div class="dc-trust__copy">
          <h4 class="dc-trust__title">{{ block.settings.title | escape }}</h4>
          <p class="dc-trust__sub">{{ block.settings.subtitle | escape }}</p>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% stylesheet %}
  .dc-trust-section {
    background: #fafbfc;
    border-top: 1px solid #ececef;
    border-bottom: 1px solid #ececef;
  }
  .dc-trust__container {
    max-width: 1320px;
    margin: 0 auto;
    padding-inline: 28px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .dc-trust__item {
    display: flex;
    gap: 14px;
    align-items: center;
  }
  .dc-trust__icon {
    width: 44px;
    height: 44px;
    border-radius: 16px;
    background: #f4f5f7;
    display: grid;
    place-items: center;
    color: #0d1115;
    flex: none;
  }
  .dc-trust__title {
    font-family: "Manrope", sans-serif;
    font-size: 14.5px;
    font-weight: 700;
    margin: 0;
    color: #0d1115;
  }
  .dc-trust__sub {
    font-size: 12.5px;
    color: #6b7280;
    margin: 2px 0 0;
  }
  @media (max-width: 920px) {
    .dc-trust__container { grid-template-columns: repeat(2, 1fr); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "DC Trust Badges",
  "tag": "section",
  "class": "section-dc-trust",
  "settings": [
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 28 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 28 }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Garantia",
      "settings": [
        { "type": "select", "id": "icon", "label": "Ícone", "options": [
          { "value": "truck", "label": "Caminhão (frete)" },
          { "value": "shield", "label": "Escudo (garantia)" },
          { "value": "refresh", "label": "Setas (troca)" },
          { "value": "headset", "label": "Headset (atendimento)" },
          { "value": "lock", "label": "Cadeado (segurança)" }
        ], "default": "truck" },
        { "type": "text", "id": "title", "label": "Título", "default": "Frete grátis" },
        { "type": "text", "id": "subtitle", "label": "Subtítulo", "default": "Em compras a partir de R$ 199" }
      ]
    }
  ],
  "presets": [
    {
      "name": "DC Trust Badges",
      "blocks": [
        { "type": "badge", "settings": { "icon": "truck", "title": "Frete grátis", "subtitle": "Em compras a partir de R$ 199" } },
        { "type": "badge", "settings": { "icon": "shield", "title": "Garantia oficial", "subtitle": "12 meses em todos os produtos" } },
        { "type": "badge", "settings": { "icon": "refresh", "title": "Troca fácil", "subtitle": "7 dias para trocar ou devolver" } },
        { "type": "badge", "settings": { "icon": "headset", "title": "Atendimento humano", "subtitle": "Seg a sáb, das 8h às 20h" } }
      ]
    }
  ]
}
{% endschema %}

{%- liquid
  assign reviews = product.metafields.custom.reviews_items.value
  assign rating_meta = product.metafields.reviews.rating.value
  assign rating_avg = 0
  if rating_meta != blank and rating_meta.rating != blank
    assign rating_avg = rating_meta.rating | times: 1.0
  endif
  assign rating_count = product.metafields.reviews.rating_count | default: 0

  assign initial_show = section.settings.initial_show | default: 4
-%}

<section
  id="dc-pdp-reviews"
  class="dc-pdp-rv-section"
  style="padding-block: {{ section.settings.padding_top | default: 64 }}px {{ section.settings.padding_bottom | default: 80 }}px;"
>
  <div class="dc-pdp-rv__container">
    <header class="dc-pdp-rv__head">
      <div>
        <p class="dc-pdp-rv__eyebrow">{{ section.settings.eyebrow | default: 'O que dizem os clientes' | escape }}</p>
        <h2 class="dc-pdp-rv__title">{{ section.settings.heading | default: 'Avaliações verificadas' | escape }}</h2>
      </div>
      {%- if rating_count > 0 -%}
        <div class="dc-pdp-rv__summary">
          <div class="dc-pdp-rv__avg">{{ rating_avg | round: 1 | replace: '.', ',' }}</div>
          <div class="dc-pdp-rv__avg-meta">
            <div class="dc-pdp-rv__stars" aria-hidden="true">
              {%- assign full = rating_avg | round -%}
              {%- for i in (1..5) -%}{%- if i <= full -%}★{%- else -%}<span class="dc-pdp-rv__star-dim">★</span>{%- endif -%}{%- endfor -%}
            </div>
            <div class="dc-pdp-rv__avg-count">{{ rating_count }} {% if rating_count == 1 %}avaliação{% else %}avaliações{% endif %}</div>
          </div>
        </div>
      {%- endif -%}
    </header>

    {%- if reviews != blank and reviews.size > 0 -%}
      <ul class="dc-pdp-rv__list" data-dc-rv-list data-initial="{{ initial_show }}">
        {%- for r in reviews -%}
          <li class="dc-pdp-rv__item{% if forloop.index > initial_show %} is-hidden{% endif %}">
            <div class="dc-pdp-rv__item-head">
              <span class="dc-pdp-rv__avatar" aria-hidden="true">{{ r.name | slice: 0, 1 }}</span>
              <div class="dc-pdp-rv__author">
                <div class="dc-pdp-rv__name">
                  {{ r.name | escape }}
                  {%- if r.verified -%}
                    <span class="dc-pdp-rv__verified" title="Compra verificada">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 16 9"/></svg>
                    </span>
                  {%- endif -%}
                </div>
                <div class="dc-pdp-rv__meta">
                  <span class="dc-pdp-rv__stars dc-pdp-rv__stars--sm" aria-label="Nota: {{ r.rating }} de 5">
                    {%- for i in (1..5) -%}{%- if i <= r.rating -%}★{%- else -%}<span class="dc-pdp-rv__star-dim">★</span>{%- endif -%}{%- endfor -%}
                  </span>
                  <span class="dc-pdp-rv__sep">·</span>
                  <time class="dc-pdp-rv__date" datetime="{{ r.date }}">
                    {%- assign parts = r.date | split: '-' -%}
                    {%- assign year = parts[0] -%}
                    {%- assign month = parts[1] -%}
                    {%- assign day = parts[2] -%}
                    {{ day }}/{{ month }}/{{ year }}
                  </time>
                </div>
              </div>
            </div>
            {%- if r.title != blank -%}
              <h4 class="dc-pdp-rv__heading">{{ r.title | escape }}</h4>
            {%- endif -%}
            <p class="dc-pdp-rv__body">{{ r.body | escape }}</p>
          </li>
        {%- endfor -%}
      </ul>

      {%- if reviews.size > initial_show -%}
        <button type="button" class="dc-pdp-rv__more" data-dc-rv-more>
          <span class="dc-pdp-rv__more-show">Ver mais avaliações ({{ reviews.size | minus: initial_show }})</span>
          <span class="dc-pdp-rv__more-hide">Ver menos</span>
        </button>
      {%- endif -%}
    {%- else -%}
      <div class="dc-pdp-rv__empty">
        <p>Este produto ainda não tem avaliações escritas.</p>
        <p class="dc-pdp-rv__empty-sub">Comprou? Conta pra gente como foi.</p>
      </div>
    {%- endif -%}

    {%- if section.settings.whatsapp_number != blank -%}
      {%- capture review_msg -%}Olá! Comprei o produto "{{ product.title }}" na DropChina e quero deixar minha avaliação:{%- endcapture -%}
      <div class="dc-pdp-rv__cta-row">
        <a
          href="https://wa.me/{{ section.settings.whatsapp_number }}?text={{ review_msg | url_encode }}"
          target="_blank"
          rel="noopener"
          class="dc-pdp-rv__write"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
          Avaliar este produto
        </a>
        <span class="dc-pdp-rv__cta-note">Sua avaliação é publicada após confirmação da compra.</span>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
(function() {
  document.querySelectorAll('[data-dc-rv-more]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var list = btn.parentElement.querySelector('[data-dc-rv-list]');
      if (!list) return;
      list.classList.toggle('is-expanded');
      btn.classList.toggle('is-expanded');
    });
  });
})();
</script>

{% stylesheet %}
  .dc-pdp-rv-section { background: #ffffff; }
  .dc-pdp-rv__container {
    max-width: 1080px;
    margin: 0 auto;
    padding-inline: 28px;
  }
  .dc-pdp-rv__head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 32px;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }
  .dc-pdp-rv__eyebrow {
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #6b7280;
    font-weight: 600;
    margin: 0 0 10px;
  }
  .dc-pdp-rv__title {
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
    font-size: 36px;
    line-height: 1.05;
    letter-spacing: -0.022em;
    font-weight: 700;
    color: #0d1115;
    margin: 0;
  }
  .dc-pdp-rv__summary {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 16px 22px;
    background: #fafbfc;
    border: 1px solid #ececef;
    border-radius: 18px;
  }
  .dc-pdp-rv__avg {
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
    font-size: 42px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
    color: #0d1115;
  }
  .dc-pdp-rv__avg-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .dc-pdp-rv__stars {
    color: #f5c518;
    font-size: 16px;
    letter-spacing: 1px;
    line-height: 1;
  }
  .dc-pdp-rv__stars--sm { font-size: 13px; }
  .dc-pdp-rv__star-dim { color: #d9dade; }
  .dc-pdp-rv__avg-count {
    font-size: 13px;
    color: #6b7280;
  }

  .dc-pdp-rv__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }
  .dc-pdp-rv__item.is-hidden { display: none; }
  .dc-pdp-rv__list.is-expanded .dc-pdp-rv__item.is-hidden { display: block; }
  .dc-pdp-rv__item {
    background: #ffffff;
    border: 1px solid #ececef;
    border-radius: 18px;
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .dc-pdp-rv__item:hover {
    border-color: #d9dade;
    box-shadow: 0 8px 22px -12px rgba(13, 17, 21, 0.1);
  }
  .dc-pdp-rv__item-head {
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .dc-pdp-rv__avatar {
    width: 38px;
    height: 38px;
    border-radius: 999px;
    background: #0d1115;
    color: #ffffff;
    display: grid;
    place-items: center;
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
    font-size: 14px;
    font-weight: 700;
    flex: none;
  }
  .dc-pdp-rv__author { min-width: 0; flex: 1; }
  .dc-pdp-rv__name {
    font-size: 14.5px;
    font-weight: 700;
    color: #0d1115;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    line-height: 1.2;
  }
  .dc-pdp-rv__verified {
    color: #16a34a;
    display: inline-grid;
    place-items: center;
  }
  .dc-pdp-rv__meta {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 2px;
    font-size: 12.5px;
    color: #6b7280;
  }
  .dc-pdp-rv__sep { color: #d9dade; }
  .dc-pdp-rv__date { color: #6b7280; }
  .dc-pdp-rv__heading {
    font-family: "Manrope", sans-serif;
    font-size: 15.5px;
    font-weight: 700;
    color: #0d1115;
    margin: 4px 0 0;
    line-height: 1.3;
  }
  .dc-pdp-rv__body {
    font-size: 14px;
    color: #2a3038;
    line-height: 1.55;
    margin: 0;
  }
  .dc-pdp-rv__more {
    margin-top: 28px;
    display: inline-flex;
    align-items: center;
    height: 44px;
    padding: 0 24px;
    border-radius: 999px;
    background: #ffffff;
    border: 1px solid #d9dade;
    color: #0d1115;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.18s;
  }
  .dc-pdp-rv__more:hover {
    background: #0d1115;
    color: #ffffff;
    border-color: #0d1115;
  }
  .dc-pdp-rv__more-hide { display: none; }
  .dc-pdp-rv__more.is-expanded .dc-pdp-rv__more-show { display: none; }
  .dc-pdp-rv__more.is-expanded .dc-pdp-rv__more-hide { display: inline; }

  .dc-pdp-rv__empty {
    text-align: center;
    padding: 56px 16px;
    color: #6b7280;
  }
  .dc-pdp-rv__empty p { margin: 0; font-size: 15px; }
  .dc-pdp-rv__empty-sub { color: #6b7280; font-size: 13px; margin-top: 6px !important; }

  .dc-pdp-rv__cta-row {
    margin-top: 28px;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .dc-pdp-rv__write {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 44px;
    padding: 0 22px;
    border-radius: 999px;
    background: #0d1115;
    color: #ffffff;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    transition: background 0.18s;
  }
  .dc-pdp-rv__write:hover { background: #16a34a; }
  .dc-pdp-rv__cta-note {
    font-size: 12.5px;
    color: #6b7280;
  }

  @media (max-width: 760px) {
    .dc-pdp-rv__list { grid-template-columns: 1fr; }
    .dc-pdp-rv__title { font-size: 28px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "DC PDP Reviews",
  "tag": "section",
  "class": "section-dc-pdp-reviews",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "O que dizem os clientes" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Avaliações verificadas" },
    { "type": "text", "id": "whatsapp_number", "label": "WhatsApp pra receber avaliações (com DDI)", "default": "5511938066545", "info": "Botão 'Avaliar este produto' abre conversa pré-preenchida. Vazio = oculta." },
    { "type": "range", "id": "initial_show", "label": "Mostrar inicialmente", "min": 2, "max": 12, "step": 1, "default": 4 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 80 }
  ],
  "enabled_on": {
    "templates": ["product"]
  },
  "presets": [
    { "name": "DC PDP Reviews" }
  ]
}
{% endschema %}

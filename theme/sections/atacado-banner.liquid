{%- liquid
  assign bg_asset = section.settings.background_asset | default: 'atacado-bg.png'
-%}

<section class="atacado-banner-section section section--page-width spacing-style" style="{% render 'spacing-padding', settings: section.settings %}">
  <div class="atacado-banner" style="background-image: linear-gradient(90deg, rgba(10,29,74,0.10) 0%, rgba(10,29,74,0.55) 35%, rgba(10,29,74,0.92) 65%, rgba(10,29,74,0.98) 100%), url('{{ bg_asset | asset_url }}');">
    <div class="atacado-banner__body">
      <p class="atacado-banner__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h2 class="atacado-banner__title">{{ section.settings.heading | escape }}</h2>
      <p class="atacado-banner__lead">{{ section.settings.lead | escape }}</p>
      <ul class="atacado-banner__perks">
        {%- for block in section.blocks -%}
          {%- if block.type == 'perk' -%}
            <li {{ block.shopify_attributes }}>
              <span class="atacado-banner__perk-num">{{ block.settings.number | escape }}</span>
              <span class="atacado-banner__perk-lbl">{{ block.settings.label }}</span>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
      <div class="atacado-banner__cta">
        <a href="{{ section.settings.primary_cta_link | default: '#' }}" class="button button--primary atacado-banner__primary-btn">
          {{ section.settings.primary_cta_label | escape }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
        </a>
        {%- if section.settings.secondary_cta_label != blank -%}
          <a href="{{ section.settings.secondary_cta_link | default: '#' }}" class="atacado-banner__secondary">
            <span class="atacado-banner__wpp-dot" aria-hidden="true"></span>
            {{ section.settings.secondary_cta_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .atacado-banner-section { padding-block: 56px; }
  .atacado-banner {
    position: relative;
    border-radius: 28px;
    overflow: hidden;
    min-height: 460px;
    background-color: #0a1d4a;
    background-size: cover;
    background-position: center left;
    display: grid;
    grid-template-columns: 1fr 1.05fr;
  }
  .atacado-banner__body {
    grid-column: 2;
    padding: 60px 60px 60px 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: #fff;
    max-width: 620px;
  }
  .atacado-banner__eyebrow {
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
    color: #f5c518;
    margin: 0 0 14px;
  }
  .atacado-banner__title {
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
    font-size: 42px;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: #fff;
    margin: 0;
    max-width: 13ch;
  }
  .atacado-banner__lead {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.78);
    margin: 18px 0 0;
    max-width: 44ch;
    line-height: 1.55;
  }
  .atacado-banner__perks {
    list-style: none;
    padding: 0;
    margin: 28px 0 0;
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: 28px;
    align-items: start;
  }
  .atacado-banner__perks li {
    display: flex;
    flex-direction: column;
    gap: 6px;
    border-left: 2px solid rgba(245, 197, 24, 0.65);
    padding-left: 14px;
  }
  .atacado-banner__perk-num {
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
    font-weight: 700;
    font-size: 28px;
    line-height: 1;
    letter-spacing: -0.03em;
    color: #f5c518;
  }
  .atacado-banner__perk-lbl {
    font-size: 12.5px;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.35;
  }
  .atacado-banner__cta {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-top: 32px;
    flex-wrap: wrap;
  }
  .atacado-banner__primary-btn {
    background: #fff !important;
    color: #0a1d4a !important;
    border-color: #fff !important;
  }
  .atacado-banner__primary-btn:hover {
    background: #f5c518 !important;
    color: #0a1d4a !important;
    border-color: #f5c518 !important;
  }
  .atacado-banner__secondary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: #fff;
    font-weight: 600;
    font-size: 14.5px;
    padding: 12px 4px;
    text-decoration: none;
    transition: color 0.18s;
  }
  .atacado-banner__secondary:hover { color: #f5c518; }
  .atacado-banner__wpp-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: #25d366;
    display: inline-block;
    box-shadow: 0 0 0 4px rgba(37, 211, 102, 0.18);
    animation: wpp-pulse 2s ease-in-out infinite;
  }
  @keyframes wpp-pulse {
    0%, 100% { box-shadow: 0 0 0 4px rgba(37, 211, 102, 0.18); }
    50% { box-shadow: 0 0 0 7px rgba(37, 211, 102, 0.05); }
  }
  @media (max-width: 920px) {
    .atacado-banner { grid-template-columns: 1fr; min-height: auto; }
    .atacado-banner__body { grid-column: 1; padding: 36px 28px; }
    .atacado-banner__perks { grid-template-columns: 1fr 1fr; gap: 18px; }
    .atacado-banner__title { font-size: 32px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Atacado banner",
  "tag": "section",
  "class": "section-atacado-banner",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "ATACADO · CNPJ" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Compre como revendedor e pague menos" },
    { "type": "textarea", "id": "lead", "label": "Subtítulo", "default": "Tabela exclusiva para CNPJ a partir de 10 unidades, com nota fiscal, entrega em todo o Brasil e gerente de conta dedicado." },
    { "type": "text", "id": "background_asset", "label": "Background asset", "default": "atacado-bg.png", "info": "Nome do arquivo em theme/assets" },
    { "type": "text", "id": "primary_cta_label", "label": "CTA principal", "default": "Cadastrar CNPJ" },
    { "type": "url", "id": "primary_cta_link", "label": "Link CTA principal" },
    { "type": "text", "id": "secondary_cta_label", "label": "CTA secundário", "default": "Falar no WhatsApp" },
    { "type": "url", "id": "secondary_cta_link", "label": "Link CTA secundário" },
    { "type": "header", "content": "Espaçamento" },
    { "type": "range", "id": "padding-block-start", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 56 },
    { "type": "range", "id": "padding-block-end", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 56 }
  ],
  "blocks": [
    {
      "type": "perk",
      "name": "Perk",
      "settings": [
        { "type": "text", "id": "number", "label": "Número/destaque", "default": "−15%" },
        { "type": "richtext", "id": "label", "label": "Descrição", "default": "<p>Desconto progressivo a partir de 10 un.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Atacado · CNPJ",
      "blocks": [
        { "type": "perk", "settings": { "number": "−15%", "label": "<p>Desconto progressivo<br>a partir de 10 un.</p>" } },
        { "type": "perk", "settings": { "number": "24h", "label": "<p>Envio para todo<br>o Brasil</p>" } },
        { "type": "perk", "settings": { "number": "NF", "label": "<p>Nota fiscal<br>sempre</p>" } }
      ]
    }
  ]
}
{% endschema %}

<section class="dc-hero-section" style="padding-block: {{ section.settings.padding_top | default: 18 }}px {{ section.settings.padding_bottom | default: 0 }}px;">
  <h1 class="dc-hero__seo-h1">{{ section.settings.seo_h1 | default: 'DropChina — Cartuchos, Toners, Impressoras e Periféricos com Garantia Oficial' | escape }}</h1>
  <div class="dc-hero__container">
    <div class="dc-hero-slideshow" data-dc-slideshow data-autoplay="{{ section.settings.autoplay_ms | default: 6500 }}">
      {%- for block in section.blocks -%}
        {%- liquid
          assign slide_url = block.settings.link | default: '#'
          assign img_src = ''
          assign img_mobile_src = ''
          if block.settings.image
            assign img_src = block.settings.image | image_url: width: 1920
          elsif block.settings.image_asset != blank
            assign img_src = block.settings.image_asset | asset_url
          endif
          if block.settings.image_mobile
            assign img_mobile_src = block.settings.image_mobile | image_url: width: 1080
          elsif block.settings.image_asset_mobile != blank
            assign img_mobile_src = block.settings.image_asset_mobile | asset_url
          endif
        -%}
        <a
          href="{{ slide_url }}"
          class="dc-hero-slide {% if forloop.first %}active{% endif %}"
          data-slide-index="{{ forloop.index0 }}"
          aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
          {{ block.shopify_attributes }}
        >
          {%- if img_src != blank -%}
            <picture>
              {%- if img_mobile_src != blank -%}
                <source media="(max-width: 767px)" srcset="{{ img_mobile_src }}">
              {%- endif -%}
              <img
                src="{{ img_src }}"
                alt="{{ block.settings.alt | default: shop.name | escape }}"
                width="1920"
                height="640"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                {% if forloop.first %}fetchpriority="high"{% endif %}
                draggable="false"
              >
            </picture>
          {%- else -%}
            <div class="dc-hero-slide__placeholder"></div>
          {%- endif -%}
        </a>
      {%- endfor -%}

      {%- if section.blocks.size > 1 -%}
        <button type="button" class="dc-hero-slideshow__arrow dc-hero-slideshow__arrow--prev" data-dc-slideshow-prev aria-label="Anterior">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m15 6-6 6 6 6"/></svg>
        </button>
        <button type="button" class="dc-hero-slideshow__arrow dc-hero-slideshow__arrow--next" data-dc-slideshow-next aria-label="Próximo">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 6 6 6-6 6"/></svg>
        </button>
        <div class="dc-hero-slideshow__dots" data-dc-slideshow-dots>
          {%- for block in section.blocks -%}
            <button type="button" class="dc-hero-slideshow__dot {% if forloop.first %}active{% endif %}" data-slide-dot="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>
          {%- endfor -%}
        </div>
        <div class="dc-hero-slideshow__count">
          <span data-dc-slideshow-current>01</span>
          <span class="dc-hero-slideshow__sep">/</span>
          <span class="dc-hero-slideshow__total">{{ section.blocks.size | prepend: '0' | slice: -2, 2 }}</span>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('[data-dc-slideshow]').forEach(function(slideshow) {
      var slides = slideshow.querySelectorAll('.dc-hero-slide');
      var dots = slideshow.querySelectorAll('[data-slide-dot]');
      var currentLabel = slideshow.querySelector('[data-dc-slideshow-current]');
      var prev = slideshow.querySelector('[data-dc-slideshow-prev]');
      var next = slideshow.querySelector('[data-dc-slideshow-next]');
      var idx = 0;
      var interval = parseInt(slideshow.dataset.autoplay, 10) || 0;
      var timer = null;

      function show(i) {
        idx = ((i % slides.length) + slides.length) % slides.length;
        slides.forEach(function(s, n) {
          s.classList.toggle('active', n === idx);
          s.setAttribute('aria-hidden', n === idx ? 'false' : 'true');
        });
        dots.forEach(function(d, n) { d.classList.toggle('active', n === idx); });
        if (currentLabel) currentLabel.textContent = String(idx + 1).padStart(2, '0');
      }
      function start() {
        if (!interval || slides.length < 2) return;
        stop();
        timer = setInterval(function() { show(idx + 1); }, interval);
      }
      function stop() { if (timer) { clearInterval(timer); timer = null; } }

      if (prev) prev.addEventListener('click', function() { show(idx - 1); start(); });
      if (next) next.addEventListener('click', function() { show(idx + 1); start(); });
      dots.forEach(function(d) {
        d.addEventListener('click', function() { show(parseInt(d.dataset.slideDot, 10)); start(); });
      });
      slideshow.addEventListener('mouseenter', stop);
      slideshow.addEventListener('mouseleave', start);

      // Swipe em touch
      var touchX = null;
      slideshow.addEventListener('touchstart', function(e) {
        touchX = e.touches[0].clientX;
        stop();
      }, { passive: true });
      slideshow.addEventListener('touchend', function(e) {
        if (touchX === null) return;
        var dx = e.changedTouches[0].clientX - touchX;
        touchX = null;
        if (Math.abs(dx) > 40) show(dx < 0 ? idx + 1 : idx - 1);
        start();
      }, { passive: true });

      start();
    });
  });
</script>

{% stylesheet %}
  .dc-hero-section { background: #ffffff; }
  /* H1 SEO invisível — sinal semântico pro Google sem alterar o layout */
  .dc-hero__seo-h1 {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .dc-hero__container {
    max-width: 1320px;
    margin: 0 auto;
    padding-inline: 28px;
  }
  .dc-hero-slideshow {
    position: relative;
    width: 100%;
    border-radius: 28px;
    overflow: hidden;
    aspect-ratio: 1320 / 460;
    background: #0d1115;
    box-shadow: 0 12px 36px -16px rgba(13, 17, 21, 0.18);
  }
  @media (max-width: 920px) {
    /* Banner bem mais alto no mobile (retrato) */
    .dc-hero-slideshow { aspect-ratio: 4 / 5; border-radius: 20px; }
  }
  .dc-hero-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.7s ease;
    pointer-events: none;
    display: block;
  }
  .dc-hero-slide.active {
    opacity: 1;
    pointer-events: auto;
  }
  .dc-hero-slide picture,
  .dc-hero-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    user-select: none;
  }
  .dc-hero-slide__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #11221a 0%, #1d3a28 55%, #2a5c3b 100%);
  }
  .dc-hero-slideshow__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 52px;
    height: 52px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px);
    color: #0d1115;
    display: grid;
    place-items: center;
    box-shadow: 0 6px 18px -6px rgba(0, 0, 0, 0.35);
    transition: transform 0.2s, background 0.2s;
    z-index: 3;
    border: 0;
    cursor: pointer;
  }
  .dc-hero-slideshow__arrow:hover {
    background: #ffffff;
    transform: translateY(-50%) scale(1.06);
  }
  .dc-hero-slideshow__arrow--prev { left: 24px; }
  .dc-hero-slideshow__arrow--next { right: 24px; }
  .dc-hero-slideshow__dots {
    position: absolute;
    bottom: 22px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 3;
  }
  /* Alvo de toque 20px alto (visual 4px via background-clip) */
  .dc-hero-slideshow__dot {
    width: 28px;
    height: 20px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.35);
    background-clip: content-box;
    transition: width 0.3s, background 0.3s;
    border: 0;
    cursor: pointer;
    padding: 8px 0;
    box-sizing: border-box;
  }
  .dc-hero-slideshow__dot.active {
    width: 56px;
    background: #ffffff;
    background-clip: content-box;
  }
  .dc-hero-slideshow__count {
    position: absolute;
    top: 24px;
    right: 24px;
    background: rgba(13, 17, 21, 0.55);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #ffffff;
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.1em;
    padding: 8px 14px;
    border-radius: 999px;
    z-index: 3;
    display: flex;
    gap: 4px;
  }
  .dc-hero-slideshow__sep { opacity: 0.5; }
  .dc-hero-slideshow__total { opacity: 0.7; }
  @media (max-width: 920px) {
    .dc-hero-slideshow__arrow { width: 40px; height: 40px; }
    .dc-hero-slideshow__arrow--prev { left: 12px; }
    .dc-hero-slideshow__arrow--next { right: 12px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "DC Hero Slideshow",
  "tag": "section",
  "class": "section-dc-hero",
  "settings": [
    { "type": "text", "id": "seo_h1", "label": "H1 SEO (oculto)", "info": "Título H1 da home lido por buscadores. Invisível no layout — não altera o visual.", "default": "DropChina — Cartuchos, Toners, Impressoras e Periféricos com Garantia Oficial" },
    { "type": "range", "id": "autoplay_ms", "label": "Autoplay (ms, 0 = desligado)", "min": 0, "max": 9500, "step": 500, "default": 6500 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 80, "step": 2, "unit": "px", "default": 18 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 0 }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagem desktop (1920x640 recomendado)" },
        { "type": "image_picker", "id": "image_mobile", "label": "Imagem mobile (1080x1350 — retrato 4:5)", "info": "Arte dedicada pra telas pequenas no formato retrato 4:5 — evita corte de texto do banner" },
        { "type": "text", "id": "image_asset", "label": "Asset fallback desktop (arquivo em theme/assets)", "info": "Ex: banner-toner.webp — usado quando 'Imagem' acima não está setada" },
        { "type": "text", "id": "image_asset_mobile", "label": "Asset fallback mobile", "info": "Ex: banner-toner-mobile.webp" },
        { "type": "text", "id": "alt", "label": "Alt text (descreva a oferta do banner)" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero DropChina",
      "blocks": [
        { "type": "slide", "settings": { "image_asset": "banner-worldcup.webp", "image_asset_mobile": "banner-worldcup-mobile.webp", "alt": "Pacotes Panini World Cup 2026" } },
        { "type": "slide", "settings": { "image_asset": "banner-toner.webp", "image_asset_mobile": "banner-toner-mobile.webp", "alt": "Toner Evolut" } },
        { "type": "slide", "settings": { "image_asset": "banner-gpu.webp", "image_asset_mobile": "banner-gpu-mobile.webp", "alt": "Placa de Vídeo GT 730" } }
      ]
    }
  ]
}
{% endschema %}

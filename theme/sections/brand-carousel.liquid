<section class="brand-marquee-section" aria-label="{{ section.settings.heading | default: 'Marcas oficiais' | escape }}">
  <div class="brand-marquee-section__head">
    <p class="brand-marquee-section__eyebrow">{{ section.settings.eyebrow | default: 'Marcas oficiais' | escape }}</p>
    {%- if section.settings.heading != blank -%}
      <h3 class="brand-marquee-section__title">{{ section.settings.heading | escape }}</h3>
    {%- endif -%}
  </div>

  <div class="brand-marquee">
    <div class="brand-marquee__track" aria-hidden="false">
      {%- for block in section.blocks -%}
        {%- assign brand_alt = block.settings.alt | default: 'Marca' -%}
        <span class="brand-marquee__cell" {{ block.shopify_attributes }}>
          {%- if block.settings.logo -%}
            {{ block.settings.logo | image_url: width: 240 | image_tag:
                 loading: 'lazy',
                 alt: brand_alt,
                 class: 'brand-marquee__logo',
                 widths: '120, 240' }}
          {%- else -%}
            {{ brand_alt | escape }}
          {%- endif -%}
        </span>
      {%- endfor -%}
      {%- comment -%} Duplicar conjunto pra loop infinito sem corte {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- assign brand_alt = block.settings.alt | default: 'Marca' -%}
        <span class="brand-marquee__cell" aria-hidden="true">
          {%- if block.settings.logo -%}
            {{ block.settings.logo | image_url: width: 240 | image_tag:
                 loading: 'lazy',
                 alt: brand_alt,
                 class: 'brand-marquee__logo',
                 widths: '120, 240' }}
          {%- else -%}
            {{ brand_alt | escape }}
          {%- endif -%}
        </span>
      {%- endfor -%}
    </div>
    <div class="brand-marquee__fade brand-marquee__fade--left" aria-hidden="true"></div>
    <div class="brand-marquee__fade brand-marquee__fade--right" aria-hidden="true"></div>
  </div>
</section>

{% stylesheet %}
  .brand-marquee-section {
    padding-block: 40px;
    background: #ffffff;
  }
  .brand-marquee-section__head {
    max-width: 1320px;
    margin: 0 auto 24px;
    padding-inline: 28px;
  }
  .brand-marquee-section__eyebrow {
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #6b7280;
    font-weight: 600;
    margin: 0 0 10px;
  }
  .brand-marquee-section__title {
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
    font-size: 26px;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #0d1115;
    margin: 0;
  }
  .brand-marquee {
    position: relative;
    overflow: hidden;
    padding: 18px 0;
    background: #ffffff;
    border-top: 1px solid #ececef;
    border-bottom: 1px solid #ececef;
  }
  .brand-marquee__track {
    display: flex;
    gap: 64px;
    width: max-content;
    animation: dc-brand-marquee 40s linear infinite;
    padding: 0 32px;
    will-change: transform;
  }
  .brand-marquee:hover .brand-marquee__track {
    animation-play-state: paused;
  }
  .brand-marquee__cell {
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
    font-weight: 700;
    font-size: 22px;
    color: #6b7280;
    letter-spacing: -0.01em;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    height: 44px;
    transition: color 0.2s;
  }
  .brand-marquee__cell:hover { color: #0d1115; }
  .brand-marquee__logo {
    height: 32px;
    width: auto;
    max-width: 140px;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.7;
    transition: filter 0.2s, opacity 0.2s;
  }
  .brand-marquee__cell:hover .brand-marquee__logo {
    filter: none;
    opacity: 1;
  }
  .brand-marquee__fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 120px;
    pointer-events: none;
    z-index: 2;
  }
  .brand-marquee__fade--left {
    left: 0;
    background: linear-gradient(90deg, #ffffff 0%, transparent 100%);
  }
  .brand-marquee__fade--right {
    right: 0;
    background: linear-gradient(270deg, #ffffff 0%, transparent 100%);
  }
  @keyframes dc-brand-marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .brand-marquee__track { animation: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Brand carousel",
  "tag": "section",
  "class": "section-brand-carousel",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Marcas oficiais" },
    { "type": "text", "id": "heading", "label": "Título", "default": "+50 marcas que você confia" }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Marca",
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo (PNG transparente)" },
        { "type": "text", "id": "alt", "label": "Nome da marca", "default": "Marca" },
        { "type": "url", "id": "link", "label": "Link (opcional)" }

{%- liquid
  assign col = section.settings.collection
  assign max_products = section.settings.max_products | default: 6
  assign render_it = false
  if col != blank
    if col.products_count > 0 or section.settings.show_when_empty
      assign render_it = true
    endif
  endif

  assign cover = section.settings.cover_image
  if cover == blank and col != blank
    assign cover = col.image
  endif

  assign cta_link = section.settings.cta_link
  if cta_link == blank and col != blank
    assign cta_link = col.url
  endif
-%}

{%- if render_it -%}
  <section class="dc-spot" style="padding-block: {{ section.settings.padding_top | default: 56 }}px {{ section.settings.padding_bottom | default: 56 }}px;">
    <div class="dc-spot__container">
      <a href="{{ cta_link | default: '#' }}" class="dc-spot__cover{% if cover == blank %} dc-spot__cover--plain{% endif %}">
        {%- if cover != blank -%}
          {{ cover | image_url: width: 2000 | image_tag:
              loading: 'lazy',
              class: 'dc-spot__cover-img',
              alt: section.settings.heading | default: col.title,
              widths: '750, 1100, 1500, 2000',
              sizes: '100vw' }}
        {%- endif -%}
        <span class="dc-spot__overlay" aria-hidden="true"></span>
        <span class="dc-spot__content">
          {%- if section.settings.eyebrow != blank -%}
            <span class="dc-spot__eyebrow">{{ section.settings.eyebrow | escape }}</span>
          {%- endif -%}
          <span class="dc-spot__title">{{ section.settings.heading | default: col.title | escape }}</span>
          {%- if section.settings.subheading != blank -%}
            <span class="dc-spot__sub">{{ section.settings.subheading | escape }}</span>
          {%- endif -%}
          <span class="dc-spot__cta">
            {{ section.settings.cta_label | default: 'Explorar categoria' | escape }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
          </span>
        </span>
      </a>

      {%- if col.products_count > 0 -%}
        <div class="dc-spot__rail">
          {%- for p in col.products limit: max_products -%}
            {% render 'dc-product-card', product: p %}
          {%- endfor -%}
        </div>
      {%- elsif section.settings.show_when_empty -%}
        <p class="dc-spot__soon">Catálogo chegando — fique de olho. <a href="{{ cta_link | default: '#' }}">Ver categoria →</a></p>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% stylesheet %}
  .dc-spot { background: #ffffff; }
  .dc-spot__container {
    max-width: 1320px;
    margin: 0 auto;
    padding-inline: 28px;
  }
  .dc-spot__cover {
    position: relative;
    display: flex;
    align-items: flex-end;
    min-height: 340px;
    border-radius: 28px;
    overflow: hidden;
    text-decoration: none;
    background: #0d1115;
    isolation: isolate;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .dc-spot__cover:hover {
    transform: translateY(-3px);
    box-shadow: 0 24px 50px -22px rgba(13, 17, 21, 0.4);
  }
  .dc-spot__cover--plain {
    background: linear-gradient(120deg, #0d1115 0%, #1d2733 60%, #0e4f3a 100%);
  }
  .dc-spot__cover-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    transition: transform 0.5s ease;
  }
  .dc-spot__cover:hover .dc-spot__cover-img { transform: scale(1.04); }
  .dc-spot__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(90deg, rgba(13,17,21,0.85) 0%, rgba(13,17,21,0.5) 50%, rgba(13,17,21,0.1) 100%);
  }
  .dc-spot__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 44px;
    max-width: 60%;
  }
  .dc-spot__eyebrow {
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #6ea8e6;
    font-weight: 700;
  }
  .dc-spot__title {
    font-family: "Bricolage Grotesque", "Manrope", sans-serif;
    font-size: 46px;
    line-height: 1.02;
    letter-spacing: -0.03em;
    font-weight: 800;
    color: #ffffff;
    text-shadow: 0 2px 24px rgba(0,0,0,0.3);
  }
  .dc-spot__sub {
    font-size: 16px;
    color: rgba(255,255,255,0.88);
    max-width: 46ch;
    line-height: 1.5;
  }
  .dc-spot__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    align-self: flex-start;
    margin-top: 8px;
    height: 48px;
    padding: 0 24px;
    border-radius: 999px;
    background: #ffffff;
    color: #0d1115;
    font-weight: 700;
    font-size: 14.5px;
    transition: gap 0.2s ease;
  }
  .dc-spot__cover:hover .dc-spot__cta { gap: 12px; }
  .dc-spot__rail {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc((100% - 5 * 18px) / 6);
    gap: 18px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    margin-top: 24px;
    padding-bottom: 8px;
  }
  .dc-spot__rail::-webkit-scrollbar { display: none; }
  .dc-spot__rail > * { scroll-snap-align: start; min-width: 0; }
  @media (max-width: 1100px) { .dc-spot__rail { grid-auto-columns: calc((100% - 3 * 18px) / 4); } }
  @media (max-width: 760px) {
    .dc-spot__rail { grid-auto-columns: calc((100% - 18px) / 2); }
    .dc-spot__content { max-width: 100%; padding: 28px; }
    .dc-spot__title { font-size: 32px; }
    .dc-spot__cover { min-height: 260px; }
  }
  .dc-spot__soon {
    margin-top: 20px;
    text-align: center;
    color: #6b7280;
    font-size: 14.5px;
  }
  .dc-spot__soon a { color: #0d1115; font-weight: 600; text-decoration: none; }
  .dc-spot__soon a:hover { text-decoration: underline; }
{% endstylesheet %}

{% schema %}
{
  "name": "DC Categoria em destaque",
  "tag": "section",
  "class": "section-dc-spotlight",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Categoria em destaque", "info": "A capa e os produtos vêm desta coleção. Some sozinha se estiver vazia (a menos que 'Mostrar vazia' esteja ligado)." },
    { "type": "image_picker", "id": "cover_image", "label": "Capa (sobrepõe a imagem da coleção)", "info": "Banner largo recomendado: 2000x680. Se vazio, usa a imagem da própria coleção." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Em destaque" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Impressão 3D" },
    { "type": "textarea", "id": "subheading", "label": "Subtítulo", "default": "Impressoras, filamentos, resinas e acessórios — do primeiro projeto à produção." },
    { "type": "text", "id": "cta_label", "label": "Texto do botão", "default": "Explorar categoria" },
    { "type": "url", "id": "cta_link", "label": "Link do botão (vazio = a própria coleção)" },
    { "type": "range", "id": "max_products", "label": "Máx. produtos no preview", "min": 4, "max": 12, "step": 1, "default": 6 },
    { "type": "checkbox", "id": "show_when_empty", "label": "Mostrar mesmo sem produtos (preview)", "default": false },
    { "type": "header", "content": "Espaçamento" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 56 }
  ],
  "presets": [
    { "name": "DC Categoria em destaque" }
  ]
}
{% endschema %}

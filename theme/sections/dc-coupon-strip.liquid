<section class="dc-coupon-strip-section" style="padding-block: {{ section.settings.padding_top | default: 12 }}px {{ section.settings.padding_bottom | default: 12 }}px;">
  <div class="dc-coupon-strip__container">
    <div class="dc-coupon-strip__bar">
      <div class="dc-coupon-strip__copy">
        {%- if section.settings.icon != blank -%}
          <span class="dc-coupon-strip__icon" aria-hidden="true">{{ section.settings.icon }}</span>
        {%- endif -%}
        <div class="dc-coupon-strip__text">
          {%- if section.settings.heading != blank -%}
            <b>{{ section.settings.heading | escape }}</b>
          {%- endif -%}
          {%- if section.settings.body_html != blank -%}
            {{ section.settings.body_html }}
          {%- elsif section.settings.code != blank -%}
            Use o cupom <code class="dc-coupon-strip__code">{{ section.settings.code | escape }}</code>{% if section.settings.detail != blank %} {{ section.settings.detail | escape }}{% endif %}
          {%- endif -%}
        </div>
      </div>
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_link | default: '#' }}" class="dc-coupon-strip__cta">
          {{ section.settings.cta_label | escape }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg>
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .dc-coupon-strip-section { background: #ffffff; }
  .dc-coupon-strip__container {
    max-width: 1320px;
    margin: 0 auto;
    padding-inline: 28px;
  }
  .dc-coupon-strip__bar {
    background: linear-gradient(90deg, #fff5da 0%, #fde8e8 100%);
    border: 1px dashed #e7c97a;
    color: #6b4f15;
    border-radius: 16px;
    padding: 14px 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    font-size: 13.5px;
    flex-wrap: wrap;
  }
  .dc-coupon-strip__copy {
    display: flex;
    align-items: center;
    gap: 14px;
    flex: 1;
    min-width: 0;
  }
  .dc-coupon-strip__icon { font-size: 22px; }
  .dc-coupon-strip__text b { color: #0d1115; font-weight: 700; }
  .dc-coupon-strip__code {
    font-family: "JetBrains Mono", monospace;
    font-weight: 700;
    letter-spacing: 0.08em;
    background: rgba(0, 0, 0, 0.05);
    padding: 4px 10px;
    border-radius: 6px;
    color: #0d1115;
    display: inline-block;
  }
  .dc-coupon-strip__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 40px;
    padding: 0 18px;
    border-radius: 999px;
    background: #0d1115;
    color: #ffffff;
    font-size: 13.5px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.18s;
    white-space: nowrap;
  }
  .dc-coupon-strip__cta:hover { background: #d62828; }
{% endstylesheet %}

{% schema %}
{
  "name": "DropChina Coupon Strip",
  "tag": "section",
  "class": "section-dc-coupon-strip",
  "settings": [
    { "type": "text", "id": "icon", "label": "Ícone (emoji)", "default": "🎟️" },
    { "type": "text", "id": "heading", "label": "Destaque (negrito)", "default": "Primeira compra?" },
    { "type": "richtext", "id": "body_html", "label": "Conteúdo HTML (sobrescreve code+detail)" },
    { "type": "text", "id": "code", "label": "Código do cupom", "default": "DROP10" },
    { "type": "text", "id": "detail", "label": "Detalhe após código", "default": "e ganhe 10% OFF. Frete grátis acima de R$ 199." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Resgatar agora" },
    { "type": "url", "id": "cta_link", "label": "CTA link" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 12 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 12 }
  ],
  "presets": [
    { "name": "Cupom DropChina" }
  ]
}
{% endschema %}

{% comment %}
  Botão WhatsApp flutuante — visível em todas as páginas
{% endcomment %}

{%- assign phone_digits = section.settings.phone | remove: '+' | remove: ' ' | remove: '-' | remove: '(' | remove: ')' -%}
{%- comment -%} Esconder na PDP pra não sobrepor o sticky-buy {%- endcomment -%}
{% if phone_digits != blank and template.name != 'product' %}
  <a
    href="https://wa.me/{{ phone_digits }}{% if section.settings.message != blank %}?text={{ section.settings.message | url_encode }}{% endif %}"
    class="whatsapp-float"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="{{ section.settings.aria_label | default: 'Fale conosco no WhatsApp' }}"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28" fill="#fff" aria-hidden="true" focusable="false">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
    </svg>
  </a>
{% endif %}

<style>
  .whatsapp-float {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--dc-green, #22c55e);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(34, 197, 94, 0.4);
    z-index: var(--dc-z-float, 999);
    transition: transform var(--dc-duration, 200ms) var(--dc-ease, cubic-bezier(0.4, 0, 0.2, 1)),
                box-shadow var(--dc-duration, 200ms) var(--dc-ease, cubic-bezier(0.4, 0, 0.2, 1)),
                background var(--dc-duration, 200ms) var(--dc-ease, cubic-bezier(0.4, 0, 0.2, 1));
  }
  .whatsapp-float:hover {
    transform: scale(1.08);
    background: var(--dc-green-hover, #16a34a);
    box-shadow: 0 12px 32px rgba(34, 197, 94, 0.5);
  }
  .whatsapp-float:focus-visible {
    outline: 3px solid var(--dc-focus-ring, #0f4fa8);
    outline-offset: 4px;
  }
  @media (max-width: 768px) {
    .whatsapp-float {
      width: 52px;
      height: 52px;
      bottom: 16px;
      right: 16px;
    }
    .whatsapp-float svg {
      width: 24px;
      height: 24px;
    }
  }
</style>

{% schema %}
{
  "name": "WhatsApp flutuante",
  "settings": [
    {
      "type": "text",
      "id": "phone",
      "label": "Número WhatsApp (com código país, ex: 5511938066545)",
      "default": "5511938066545"
    },
    {
      "type": "textarea",
      "id": "message",
      "label": "Mensagem inicial (opcional)",
      "default": "Olá! Vim pelo site DropChina e gostaria de mais informações."
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Aria-label (acessibilidade)",
      "default": "Fale conosco no WhatsApp"
    }
  ],
  "presets": [
    { "name": "WhatsApp flutuante" }
  ]
}
{% endschema %}

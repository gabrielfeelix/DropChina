{% doc %}
  Emite JSON-LD BreadcrumbList em páginas de produto e coleção.
  Elegível a rich results (breadcrumb) na SERP do Google.
  Renderizado no <head> via theme.liquid — usa os objetos globais `product`/`collection`.
{% enddoc %}
{%- liquid
  assign origin = request.origin
-%}
{%- if request.page_type == 'product' and product != blank -%}
  {%- assign col = product.collections.first -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Início",
        "item": {{ origin | json }}
      },
      {%- if col != blank -%}
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ col.title | json }},
        "item": {{ origin | append: col.url | json }}
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": {{ product.title | json }},
        "item": {{ origin | append: product.url | json }}
      }
      {%- else -%}
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ product.title | json }},
        "item": {{ origin | append: product.url | json }}
      }
      {%- endif -%}
    ]
  }
  </script>
{%- elsif request.page_type == 'collection' and collection != blank -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Início",
        "item": {{ origin | json }}
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ collection.title | json }},
        "item": {{ origin | append: collection.url | json }}
      }
    ]
  }
  </script>
{%- endif -%}

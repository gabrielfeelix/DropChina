{%- doc -%}
  DropChina product card.
  @param {object} product - Shopify Product object
  @example
  {% render 'dc-product-card', product: product %}
{%- enddoc -%}

{%- liquid
  assign p_var = product.selected_or_first_available_variant
  assign on_sale = false
  if p_var.compare_at_price > p_var.price
    assign on_sale = true
    assign pct_off = p_var.compare_at_price | minus: p_var.price | times: 100 | divided_by: p_var.compare_at_price | round
  endif

  assign rating_meta = product.metafields.reviews.rating.value
  assign rating_avg = 0
  if rating_meta != blank and rating_meta.rating != blank
    assign rating_avg = rating_meta.rating | times: 1.0
  endif
  assign rating_count = product.metafields.reviews.rating_count | default: 0

  assign is_best = false
  if product.tags contains 'mais-vendido' or product.tags contains 'bestseller' or product.tags contains 'best'
    assign is_best = true
  endif
  assign is_new = false
  if product.tags contains 'novo' or product.tags contains 'new'
    assign is_new = true
  endif

  assign in_wishlist = false
  if customer and customer.metafields.dropchina.wishlist != blank
    assign wishlist_val = customer.metafields.dropchina.wishlist | json
    if wishlist_val contains product.id
      assign in_wishlist = true
    endif
  endif
-%}

{%- if product == blank or product.url == blank -%}
{%- else -%}
<article class="dc-card" data-product-id="{{ product.id }}" data-product-handle="{{ product.handle }}">
  <div class="dc-card__media">
    <a href="{{ product.url }}" class="dc-card__media-link" aria-label="{{ product.title | escape }}">
      {%- if product.featured_image != blank -%}
        {{ product.featured_image | image_url: width: 480 | image_tag:
            loading: 'lazy',
            alt: product.title,
            class: 'dc-card__img',
            widths: '240, 480, 720' }}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'dc-card__img dc-card__img--placeholder' }}
      {%- endif -%}
    </a>

    <div class="dc-card__badges">
      {%- if is_best -%}
        <span class="dc-card__badge dc-card__badge--best">Mais vendido</span>
      {%- elsif is_new -%}
        <span class="dc-card__badge dc-card__badge--new">Novo</span>
      {%- endif -%}
      {%- if on_sale -%}
        <span class="dc-card__badge dc-card__badge--sale">−{{ pct_off }}%</span>
      {%- endif -%}
    </div>

    <button
      type="button"
      class="dc-card__wish{% if in_wishlist %} is-active{% endif %}"
      data-dc-wish
      data-product-id="{{ product.id }}"
      aria-label="{% if in_wishlist %}Remover dos favoritos{% else %}Adicionar aos favoritos{% endif %}"
      aria-pressed="{{ in_wishlist }}"
    >
      <svg class="dc-card__wish-outline" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      <svg class="dc-card__wish-fill" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
    </button>

  </div>

  <div class="dc-card__body">
    {%- if product.vendor != blank -%}
      <div class="dc-card__brand">{{ product.vendor }}</div>
    {%- endif -%}
    <a href="{{ product.url }}" class="dc-card__title-link">
      <h4 class="dc-card__title">{{ product.title }}</h4>
    </a>
    {%- if rating_count > 0 -%}
      <div class="dc-card__rating">
        <span class="dc-card__stars" aria-hidden="true">
          {%- assign full = rating_avg | round -%}
          {%- for i in (1..5) -%}{%- if i <= full -%}★{%- else -%}<span style="opacity:.25">★</span>{%- endif -%}{%- endfor -%}
        </span>
        <span class="dc-card__rating-avg">{{ rating_avg | round: 1 }}</span>
        <span class="dc-card__rating-sep">·</span>
        <span class="dc-card__rating-count">{{ rating_count }}</span>
      </div>
    {%- endif -%}
    <div class="dc-card__price-stack">
      {%- if on_sale -%}
        <span class="dc-card__price-old">{{ p_var.compare_at_price | money }}</span>
      {%- endif -%}
      <div class="dc-card__price-row">
        <span class="dc-card__price{% if on_sale %} dc-card__price--sale{% endif %}">{{ p_var.price | money }}</span>
      </div>
    </div>
    {%- assign installment = p_var.price | divided_by: 12 -%}
    <div class="dc-card__installments">em <b>12x {{ installment | money }}</b> sem juros</div>
    {%- if p_var.price >= 19900 -%}
      <div class="dc-card__shipping"><span class="dc-card__pulse"></span> Frete grátis</div>
    {%- endif -%}

    {%- if p_var.available -%}
      <button
        type="button"
        class="dc-card__add"
        data-dc-add
        data-variant-id="{{ p_var.id }}"
        aria-label="Adicionar {{ product.title | escape }} ao carrinho"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 4h2l2.5 12.5a2 2 0 0 0 2 1.5h8a2 2 0 0 0 2-1.5L21 8H6"/><circle cx="10" cy="21" r="1.4"/><circle cx="17" cy="21" r="1.4"/></svg>
        <span>Adicionar ao carrinho</span>
      </button>
    {%- else -%}
      <button type="button" class="dc-card__add dc-card__add--soldout" disabled>
        Esgotado
      </button>
    {%- endif -%}
  </div>
</article>
{%- endif -%}

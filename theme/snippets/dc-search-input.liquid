{%- doc -%}
  Renders DropChina inline search input in header center column.
  Self-contained: estilos próprios via {% stylesheet %} pra não depender
  de overrides externos.
{%- enddoc -%}

<script src="{{ 'dc-search.js' | asset_url }}" defer="defer"></script>

<div
  class="dc-search predictive-search color-scheme-1"
  role="search"
  aria-label="Buscar produtos"
>
  <form
    action="{{ routes.search_url | default: '/search' }}"
    method="get"
    role="search"
    class="predictive-search-form dc-search__form"
    ref="form"
    on:keydown="/onSearchKeyDown"
  >
    <div class="predictive-search-form__header dc-search__inner">
      <div class="predictive-search-form__header-inner dc-search__row">
        <input
          class="search-input dc-search__field"
          id="dc-search-input"
          type="search"
          name="q"
          role="combobox"
          aria-expanded="false"
          aria-owns="predictive-search-results"
          aria-controls="predictive-search-results"
          aria-haspopup="listbox"
          aria-autocomplete="list"
          autocomplete="off"
          autocorrect="off"
          spellcheck="false"
          placeholder="Buscar cartuchos, toners, placas de vídeo..."
          ref="searchInput"
          on:input="/search"
          on:keydown="/onSearchKeyDown"
        >
        <input type="hidden" name="options[prefix]" value="last">

        <button
          type="submit"
          class="dc-search__submit"
          aria-label="Buscar"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="predictive-search-form__content-wrapper dc-search__results-wrapper">
      <div
        id="predictive-search-results"
        class="predictive-search-form__content dc-search__results"
        ref="predictiveSearchResults"
        on:click="/handleModalClick"
        role="listbox"
        aria-label="Resultados da busca"
      ></div>

      <div class="predictive-search-form__footer dc-search__footer" hidden>
        <button
          class="dc-search__view-all"
          ref="viewAllButton"
          type="submit"
        >
          Ver todos os resultados
        </button>
      </div>
    </div>
  </form>
</div>

{% stylesheet %}
  /* Search wrapper toma toda a largura disponível da center column */
  .dc-search {
    width: 100%;
    max-width: 640px;
    margin-inline: auto;
    position: relative;
    display: block;
  }
  .dc-search__form {
    width: 100%;
    position: relative;
  }
  .dc-search__inner,
  .dc-search__row {
    width: 100%;
    position: relative;
    display: block;
  }
  /* Input redondo grande */
  .dc-search__field {
    width: 100%;
    height: 50px;
    border-radius: 999px;
    border: 1px solid #d9dade;
    background: #ffffff;
    padding: 0 56px 0 22px;
    font-size: 15px;
    line-height: 1;
    color: #0d1115;
    font-family: inherit;
    outline: none;
    box-sizing: border-box;
    transition: border-color 0.18s, box-shadow 0.18s;
    -webkit-appearance: none;
    appearance: none;
  }
  .dc-search__field::placeholder { color: #9ca3af; }
  .dc-search__field::-webkit-search-cancel-button,
  .dc-search__field::-webkit-search-decoration {
    -webkit-appearance: none;
    display: none;
  }
  .dc-search__field:focus {
    border-color: #0d1115;
    box-shadow: 0 0 0 3px rgba(13, 17, 21, 0.12);
  }
  /* Lupa preta redonda no canto direito */
  .dc-search__submit {
    position: absolute;
    right: 6px;
    top: 50%;
    transform: translateY(-50%);
    width: 38px;
    height: 38px;
    border-radius: 999px;
    background: #0d1115;
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    cursor: pointer;
    padding: 0;
    transition: background 0.18s;
  }
  .dc-search__submit:hover { background: #d62828; }
  .dc-search__submit svg {
    width: 18px;
    height: 18px;
    color: #ffffff;
    stroke: #ffffff;
  }

  /* Results dropdown (predictive) */
  .dc-search__results-wrapper {
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    right: 0;
    background: #ffffff;
    border: 1px solid #ececef;
    border-radius: 16px;
    box-shadow: 0 24px 60px -20px rgba(13, 17, 21, 0.28);
    z-index: 70;
    display: none;
  }
  .dc-search[data-open="true"] .dc-search__results-wrapper { display: block; }
  .dc-search__results {
    padding: 18px;
    max-height: 480px;
    overflow-y: auto;
  }
  .dc-search__footer {
    padding: 12px 18px;
    border-top: 1px solid #ececef;
  }
  .dc-search__view-all {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: transparent;
    border: 0;
    color: #d62828;
    font-size: 13.5px;
    font-weight: 600;
    cursor: pointer;
  }

  /* Garante que o slot center do header não trunca o search */
  header.header .header__column--center {
    width: 100%;
    justify-self: stretch;
  }
  header.header .header__columns {
    --header-left: minmax(max-content, 0.5fr);
    --header-center: minmax(320px, 640px);
    --header-right: minmax(max-content, 0.5fr);
  }
  @media (max-width: 920px) {
    header.header .header__columns {
      --header-center: minmax(160px, 1fr);
    }
    .dc-search__field { height: 44px; font-size: 14px; }
  }
{% endstylesheet %}

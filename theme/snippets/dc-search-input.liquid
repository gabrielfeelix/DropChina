{%- doc -%}
  Renders the DropChina custom search input inline inside the header top row.
  Usa fetch direto pra /search/suggest + injeção manual (não depende do
  predictive-search.js JS do Tinker que tinha problemas de morph).
{%- enddoc -%}

<script>
  (function() {
    if (window.__dcSearchInit) return;
    window.__dcSearchInit = true;
    let dcSearchTimer = null;
    let dcSearchAbort = null;

    function initDcSearch() {
      const input = document.querySelector('.dc-search-input__field');
      const results = document.querySelector('.dc-search-input__results');
      const wrapper = document.querySelector('.dc-search-input__results-wrapper');
      if (!input || !results || !wrapper) return;

      wrapper.hidden = true;

      console.log('[DC Search] Initialized', { input, results, wrapper });

      input.addEventListener('input', function(e) {
        const q = input.value.trim();
        console.log('[DC Search] Input event:', q);
        if (dcSearchTimer) clearTimeout(dcSearchTimer);
        if (dcSearchAbort) dcSearchAbort.abort();
        if (!q) {
          wrapper.hidden = true;
          results.innerHTML = '';
          return;
        }
        dcSearchTimer = setTimeout(function() {
          dcSearchAbort = new AbortController();
          const url = '/search/suggest?section_id=predictive-search&q=' + encodeURIComponent(q) + '&resources%5Blimit%5D=8&resources%5Btype%5D=product%2Ccollection';
          console.log('[DC Search] Fetching:', url);
          fetch(url, { signal: dcSearchAbort.signal })
            .then(function(r) {
              console.log('[DC Search] Response status:', r.status);
              return r.text();
            })
            .then(function(html) {
              const tmp = document.createElement('div');
              tmp.innerHTML = html;
              const inner = tmp.querySelector('#predictive-search-results') || tmp.querySelector('.predictive-search-dropdown') || tmp.querySelector('.shopify-section');
              console.log('[DC Search] Parsed inner:', inner);
              if (inner) {
                results.innerHTML = inner.innerHTML;
                wrapper.hidden = false;
                console.log('[DC Search] Injected. Dropdown should be visible now.');
              } else {
                console.warn('[DC Search] No inner container found in response. HTML preview:', html.slice(0, 500));
              }
            })
            .catch(function(err) {
              if (err.name !== 'AbortError') console.error('[DC Search] Error:', err);
            });
        }, 200);
      });

      input.addEventListener('blur', function() {
        setTimeout(function() { wrapper.hidden = true; }, 200);
      });
      input.addEventListener('focus', function() {
        if (results.innerHTML.trim()) wrapper.hidden = false;
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initDcSearch);
    } else {
      initDcSearch();
    }
  })();
</script>

<div
  class="dc-search-input predictive-search color-scheme-1"
  role="search"
  aria-label="Buscar produtos"
>
  <form
    action="{{ routes.search_url | default: '/search' }}"
    method="get"
    role="search"
    class="predictive-search-form dc-search-input__form"
    ref="form"
    on:keydown="/onSearchKeyDown"
  >
    <div class="predictive-search-form__header dc-search-input__inner">
      <div class="predictive-search-form__header-inner">
        <input
          class="search-input dc-search-input__field"
          id="dc-search-input"
          type="search"
          name="q"
          role="combobox"
          aria-expanded="false"
          aria-owns="predictive-search-results"
          aria-controls="predictive-search-results"
          aria-haspopup="listbox"
          aria-autocomplete="list"
          autocomplete="off"
          autocorrect="off"
          spellcheck="false"
          placeholder="Digite o que você procura"
          ref="searchInput"
          on:input="/search"
          on:keydown="/onSearchKeyDown"
        >
        <input type="hidden" name="options[prefix]" value="last">

        <button
          type="submit"
          class="dc-search-input__submit"
          aria-label="Buscar"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>

        <button
          type="button"
          class="button-unstyled dc-search-input__reset"
          ref="resetButton"
          hidden
          on:click="/resetSearch"
          aria-label="Limpar busca"
        >
          ✕
        </button>
      </div>
    </div>

    <div class="predictive-search-form__content-wrapper dc-search-input__results-wrapper">
      <div
        id="predictive-search-results"
        class="predictive-search-form__content dc-search-input__results"
        ref="predictiveSearchResults"
        on:click="/handleModalClick"
        role="listbox"
        aria-label="Resultados da busca"
      ></div>

      <div class="predictive-search-form__footer dc-search-input__footer" hidden>
        <button
          class="button predictive-search__search-button dc-search-input__view-all"
          ref="viewAllButton"
          type="submit"
        >
          Ver todos os resultados
        </button>
      </div>
    </div>
  </form>
</div>

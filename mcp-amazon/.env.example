# Modelo do .env do cliente SP-API — copie para .env e preencha com os valores reais.
# Valores vêm do Seller Central > Apps & Services > Develop Apps (Solution Provider Portal).
# NÃO coloque valores reais aqui — este arquivo VAI para o git.

# Credenciais do app LWA (Login with Amazon) — criadas no Seller Central
LWA_CLIENT_ID=
LWA_CLIENT_SECRET=

# Refresh token obtido após self-authorization do app no Seller Central
# Instrução: npm run authorize  (leia o comentário no arquivo authorize.ts)
SP_API_REFRESH_TOKEN=

# Região da SP-API. Para o Brasil (Amazon.com.br), use "na" (North America cluster)
# Clusters: na (us-east-1), eu (eu-west-1), fe (us-west-2)
SP_API_REGION=na

# Marketplace ID do Brasil: A2Q3Y263D1QR3R
# Outros: ATVPDKIKX0DER (US), A1AM78C64UM0Y8 (MX), A2EUQ1WTGCTBG2 (CA)
SP_API_MARKETPLACE_ID=A2Q3Y263D1QR3R

# (Opcional) Credenciais AWS para Role-based auth — deixe em branco se usar self-authorization simples
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ROLE_ARN=

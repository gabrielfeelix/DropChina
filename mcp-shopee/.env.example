# Modelo do .env do cliente Shopee — copie para .env e preencha com os valores reais.
# Valores vêm do app criado no Shopee Open Platform (open.shopee.com).
# NÃO coloque valores reais aqui — este arquivo VAI para o git.

# Credenciais do app (geradas ao criar o app no Open Platform)
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=

# ID da loja autorizada (shop_id) — obtido após o fluxo OAuth da loja
SHOPEE_SHOP_ID=

# Região/host: "prod" usa https://partner.shopeemobile.com
#              "sandbox" usa https://partner.test-stable.shopeemobile.com
# Deixe "prod" para produção; use "sandbox" apenas para testes com conta de sandbox.
SHOPEE_REGION=prod

# URI de redirecionamento registrada no app (deve ser HTTPS e idêntica à do painel)
SHOPEE_REDIRECT_URI=https://dropchinaoficial.com.br/oauth/shopee

# ============================================================
# DropChina Importer — Chrome Extension
# Copia este arquivo pra .env e preenche os valores.
# .env é gitignored (NUNCA committa).
# ============================================================

# ===== Shopify Admin API =====
# Domain da loja Shopify (sem https://, sem trailing slash)
# Use o domínio .myshopify.com ORIGINAL (não o customizado)
SHOPIFY_STORE_DOMAIN=akfd19-1c.myshopify.com

# Custom App Admin API access token
# Como criar:
# 1. Abra: https://admin.shopify.com/store/akfd19-1c/settings/apps/development
# 2. Clica "Allow custom app development" se aparecer (1x só)
# 3. "Create an app" → nome "DropChina Importer" → Create
# 4. Aba "Configuration" → "Admin API integration" → "Configure"
# 5. Marca scopes:
#    - write_products, read_products
#    - write_inventory, read_inventory
#    - write_publications, read_publications
#    - write_files, read_files
#    - write_product_listings (opcional)
# 6. Save
# 7. Aba "API credentials" → "Install app" → "Install"
# 8. Copia o "Admin API access token" (começa com shpat_)
#    ⚠️ ESSE TOKEN SÓ APARECE 1 VEZ. Guarda também num password manager.
SHOPIFY_ADMIN_API_TOKEN=shpat_PASTE_YOUR_TOKEN_HERE

# Versão da Admin API (atualize anualmente)
SHOPIFY_API_VERSION=2026-01

# ===== Storefront público (não secret) =====
# URL pública pra abrir produto após criação
SHOPIFY_STOREFRONT_URL=https://dropchina-9753.myshopify.com

# ===== AI opcional (Magic Edit pra reescrever títulos/descrições) =====
# Deixe vazio se não for usar
# OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-api03-...
AI_PROVIDER=none

# ===== Logging =====
LOG_LEVEL=info
